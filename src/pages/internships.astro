---
import Layout from '../layouts/Layout.astro';
import { getInternships } from '../data/db.js';

export const prerender = false;

const internships = getInternships().filter(i => i.status !== 'Inactive');

// Helper to assign categories for filtering
function getCategory(id) {
  switch(id) {
    case 'computer-fundamentals':
      return 'computer-skills';
    case 'digital-marketing':
      return 'digital-marketing';
    case 'web-development':
      return 'web-development';
    case 'tally-accounting':
    case 'gst-filing':
    case 'income-tax':
      return 'accounting-gst';
    case 'ai-tools':
      return 'ai-tools';
    default:
      return 'computer-skills';
  }
}

// Helper to get custom premium badges for each internship
function getBadges(id) {
  switch(id) {
    case 'computer-fundamentals':
      return ['Practical Training', 'Office Ready', '100% Refundable'];
    case 'digital-marketing':
      return ['Popular Program', 'Certificate Included', '100% Refundable'];
    case 'web-development':
      return ['Job-Oriented', 'Practical Training', '100% Refundable'];
    case 'tally-accounting':
      return ['Job-Oriented', 'TallyPrime', '100% Refundable'];
    case 'gst-filing':
      return ['Certificate Included', 'Tax Compliance', '100% Refundable'];
    case 'income-tax':
      return ['Certificate Included', 'Tax Compliance', '100% Refundable'];
    case 'ai-tools':
      return ['Popular Program', 'Future Ready', '100% Refundable'];
    default:
      return ['Practical Training', 'Certificate Included', '100% Refundable'];
  }
}
---

<Layout 
  title="1-Month Practical Internship Programs — Web Dev, GST, AI & More | Margdarshak Darbhanga" 
  description="Apply for premium 1-month practical internship programs at Margdarshak Shikshan Sansthan. Web Development, GST Filing, Income Tax, Tally, AI Tools & more with certificate and 100% refund."
  ogImage="/assets/ai_tools_internship.png"
>
  
  <!-- Hero Section -->
  <section class="hero-gradient text-white py-10 md:py-24 relative overflow-hidden">
    <!-- Glow Blobs -->
    <div class="absolute top-1/4 left-1/10 w-96 h-96 bg-secondary/15 rounded-full filter blur-[120px] pointer-events-none animate-pulse-glow"></div>
    <div class="absolute bottom-10 right-10 w-80 h-80 bg-accent/15 rounded-full filter blur-[100px] pointer-events-none animate-float-slow"></div>
    
    <div class="max-w-[1440px] mx-auto px-4 md:px-6 relative z-10">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
        <!-- Text Content -->
        <div class="lg:col-span-7 space-y-6 text-left">
          <div class="inline-flex items-center gap-2 bg-white/5 border border-white/10 px-4 py-1.5 rounded-full backdrop-blur-md">
            <span class="w-2 h-2 rounded-full bg-secondary animate-ping"></span>
            <span class="text-xs font-bold uppercase tracking-wider text-accent font-headline">Practical Career Platform</span>
          </div>
          <h1 class="text-4xl md:text-6xl font-headline font-black leading-tight">
            Elevate Your Career with <br />
            <span class="text-gradient-purple-orange">Practical Internships</span>
          </h1>
          <p class="text-slate-300 text-base md:text-lg max-w-2xl leading-relaxed font-body">
            Bridging the gap between learning and professional employment. Work on live assignments, use industry-standard software, and gain real experience.
          </p>
          <div class="flex flex-wrap gap-4 pt-2">
            <div class="flex items-center gap-2 text-sm text-slate-200">
              <span class="material-symbols-outlined text-accent text-xl">workspace_premium</span>
              <span>Government Registered Institute</span>
            </div>
            <div class="flex items-center gap-2 text-sm text-slate-200">
              <span class="material-symbols-outlined text-accent text-xl">savings</span>
              <span>100% Refund Opportunity</span>
            </div>
          </div>
        </div>

        <!-- Visual Asset (Premium Interactive Preview Card) -->
        <div class="lg:col-span-5 relative hidden lg:block">
          <div class="absolute -inset-1 rounded-3xl bg-gradient-to-r from-secondary to-accent opacity-30 blur-lg animate-float-medium"></div>
          <div class="relative glass-card-premium p-8 rounded-3xl border border-white/10 text-white space-y-6 shadow-2xl bg-primary/45 backdrop-blur-xl">
            <div class="flex justify-between items-center">
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-full bg-secondary/15 flex items-center justify-center text-secondary border border-secondary/25">
                  <span class="material-symbols-outlined font-bold">work</span>
                </div>
                <div>
                  <h4 class="font-headline font-bold text-sm">Experience Program</h4>
                  <p class="text-[10px] text-slate-400">1-Month Smart Internships</p>
                </div>
              </div>
              <span class="text-xs bg-accent/20 text-accent font-bold px-3 py-1 rounded-full border border-accent/30 uppercase">LIVE</span>
            </div>

            <!-- Dashboard Mini Card -->
            <div class="space-y-3 bg-slate-900/60 p-4 rounded-2xl border border-white/5">
              <div class="flex justify-between text-xs">
                <span class="text-slate-400">Attendance Standard</span>
                <span class="text-accent font-bold">90%+ Required</span>
              </div>
              <div class="w-full bg-white/10 rounded-full h-2 overflow-hidden">
                <div class="bg-gradient-to-r from-secondary to-accent h-full w-[92%]"></div>
              </div>
              <p class="text-[10px] text-slate-400 flex items-center gap-1">
                <span class="material-symbols-outlined text-xs text-secondary font-bold">verified</span>
                Qualifies for 100% Registration Fee Refund
              </p>
            </div>

            <div class="grid grid-cols-2 gap-3 text-center">
              <div class="bg-white/5 p-3 rounded-xl border border-white/5">
                <div class="text-xl font-bold text-accent">100%</div>
                <div class="text-[10px] text-slate-400">Practical Work</div>
              </div>
              <div class="bg-white/5 p-3 rounded-xl border border-white/5">
                <div class="text-xl font-bold text-accent">ISO</div>
                <div class="text-[10px] text-slate-400">Certified Org</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Refund Highlight Banner -->
  <section class="relative bg-white border-b border-slate-200/60 shadow-sm z-20">
    <div class="max-w-[1440px] mx-auto px-4 md:px-6 py-6">
      <div class="glass-card-premium p-6 rounded-2xl border border-secondary/15 flex flex-col md:flex-row items-center justify-between gap-6 bg-secondary/[0.02]">
        <div class="flex items-center gap-4">
          <div class="w-12 h-12 rounded-2xl bg-secondary/10 flex items-center justify-center text-secondary border border-secondary/20">
            <span class="material-symbols-outlined text-2xl font-bold">payments</span>
          </div>
          <div>
            <h4 class="font-headline font-bold text-slate-800 text-base md:text-lg">
              100% Attendance Fee Refund Opportunity
            </h4>
            <p class="text-slate-600 text-xs md:text-sm font-medium">
              We reward dedication. Maintain 90%+ attendance and submit your weekly tasks to secure a 100% refund of your ₹1,000 fee.
            </p>
          </div>
        </div>
        <div class="flex items-center gap-3 w-full md:w-auto shrink-0 justify-end">
          <a href="/register" class="w-full md:w-auto text-center bg-primary hover:bg-primary/95 text-white font-bold text-xs px-6 py-3 rounded-xl transition-all shadow-md">
            Check My Eligibility
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Marketplace Filtering & Discovery Section -->
  <section class="py-16 bg-slate-50 min-h-[600px] relative">
    <div class="max-w-[1440px] mx-auto px-4 md:px-6 space-y-12">
      
      <!-- Sticky / Glassmorphic Search & Filters Bar -->
      <div class="glass-card-premium p-6 rounded-3xl border border-slate-200/80 shadow-premium bg-white/80 backdrop-blur-xl space-y-6">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 items-center">
          
          <!-- Search Input -->
          <div class="lg:col-span-5 relative">
            <span class="material-symbols-outlined absolute left-4 top-3.5 text-slate-400">search</span>
            <input 
              type="text" 
              id="search-input" 
              placeholder="Search Internship Programs..." 
              class="w-full pl-12 pr-4 py-3 bg-slate-100/60 border border-slate-200 rounded-2xl focus:border-secondary focus:ring-2 focus:ring-secondary/15 focus:outline-none text-slate-700 text-sm font-medium transition-all"
            />
          </div>

          <!-- Filters Info / Pill Title -->
          <div class="lg:col-span-7 flex flex-nowrap overflow-x-auto scrollbar-none gap-2 py-1 -mx-4 px-4 lg:mx-0 lg:px-0 lg:flex-wrap items-center" id="filter-pills-container">
            <button 
              data-filter="all" 
              class="filter-pill active px-4 py-2 text-xs font-bold rounded-xl transition-all duration-300 border border-secondary bg-secondary text-white shadow-glow-red shrink-0"
            >
              All Internships
            </button>
            <button 
              data-filter="digital-marketing" 
              class="filter-pill px-4 py-2 text-xs font-bold rounded-xl transition-all duration-300 border border-slate-200 bg-white text-slate-600 hover:border-secondary/40 hover:bg-secondary/5 hover:text-secondary shrink-0"
            >
              Digital Marketing
            </button>
            <button 
              data-filter="web-development" 
              class="filter-pill px-4 py-2 text-xs font-bold rounded-xl transition-all duration-300 border border-slate-200 bg-white text-slate-600 hover:border-secondary/40 hover:bg-secondary/5 hover:text-secondary shrink-0"
            >
              Web Development
            </button>
            <button 
              data-filter="accounting-gst" 
              class="filter-pill px-4 py-2 text-xs font-bold rounded-xl transition-all duration-300 border border-slate-200 bg-white text-slate-600 hover:border-secondary/40 hover:bg-secondary/5 hover:text-secondary shrink-0"
            >
              Accounting & GST
            </button>
            <button 
              data-filter="computer-skills" 
              class="filter-pill px-4 py-2 text-xs font-bold rounded-xl transition-all duration-300 border border-slate-200 bg-white text-slate-600 hover:border-secondary/40 hover:bg-secondary/5 hover:text-secondary shrink-0"
            >
              Computer Skills
            </button>
            <button 
              data-filter="ai-tools" 
              class="filter-pill px-4 py-2 text-xs font-bold rounded-xl transition-all duration-300 border border-slate-200 bg-white text-slate-600 hover:border-secondary/40 hover:bg-secondary/5 hover:text-secondary shrink-0"
            >
              AI Tools
            </button>
          </div>
          
        </div>
      </div>

      <!-- No Results State -->
      <div id="no-results" class="hidden text-center py-16 space-y-4">
        <span class="material-symbols-outlined text-5xl text-slate-400 animate-bounce">search_off</span>
        <h3 class="text-xl font-headline font-bold text-primary">No Internships Found</h3>
        <p class="text-slate-500 max-w-sm mx-auto text-sm">We couldn't find any internships matching your current search or filters. Try adjusting your search term.</p>
        <button id="reset-search" class="text-xs font-bold text-secondary underline hover:text-secondary/85">Clear Search & Filters</button>
      </div>

      <!-- Internships Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8" id="internships-grid">
        {internships.map((internship, idx) => {
          const category = getCategory(internship.id);
          const badges = getBadges(internship.id);
          const searchKeywords = [
            internship.name, 
            internship.shortDescription, 
            ...(internship.tags || []),
            category
          ].join(' ').toLowerCase();

          return (
            <div 
              data-category={category}
              data-search={searchKeywords}
              class="internship-card group glass-card-premium border border-slate-200/80 rounded-3xl overflow-hidden hover:border-secondary/35 hover:shadow-premium-hover hover-lift flex flex-col justify-between transition-all duration-300 reveal reveal-slide-up"
              style={`transition-delay: ${(idx % 3) * 80}ms`}
            >
              <div>
                <!-- Card Image & Floating Badges -->
                <div class="aspect-[16/9] overflow-hidden relative bg-slate-100">
                  <img 
                    alt={internship.name} 
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" 
                    src={internship.image} 
                    loading="lazy"
                    decoding="async"
                    width="400"
                    height="225"
                  />
                  <!-- Gradient Overlays -->
                  <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-60"></div>
                  
                  <!-- Floating Badge Header -->
                  <div class="absolute top-4 left-4 flex flex-wrap gap-1.5 max-w-[80%]">
                    {badges.slice(0, 2).map((badge, idx) => (
                      <span class={`text-[10px] font-extrabold px-2.5 py-1 rounded-full uppercase tracking-wider shadow-sm border backdrop-blur-md ${
                        idx === 0 
                          ? 'bg-secondary/90 text-white border-secondary/30' 
                          : 'bg-accent text-primary border-accent/30'
                      }`}>
                        {badge}
                      </span>
                    ))}
                  </div>

                  <!-- Floating Fee Tag -->
                  <div class="absolute bottom-4 right-4 bg-primary/90 text-white text-xs font-black px-3.5 py-1.5 rounded-xl border border-white/10 uppercase tracking-wider backdrop-blur-md shadow-md">
                    Fee: {internship.fee}
                  </div>
                </div>

                <!-- Card Body -->
                <div class="p-6 space-y-4">
                  <!-- Duration & Mode row -->
                  <div class="flex items-center gap-4 text-xs font-semibold text-slate-500">
                    <span class="flex items-center gap-1 text-secondary">
                      <span class="material-symbols-outlined text-base">schedule</span>
                      Duration: {internship.duration}
                    </span>
                    <span class="w-1.5 h-1.5 rounded-full bg-slate-300"></span>
                    <span class="flex items-center gap-1">
                      <span class="material-symbols-outlined text-base">layers</span>
                      Hybrid Mode
                    </span>
                  </div>

                  <h3 class="text-xl font-headline font-bold text-primary group-hover:text-secondary transition-colors line-clamp-1">
                    {internship.name}
                  </h3>
                  
                  <p class="text-slate-600 text-sm leading-relaxed line-clamp-2 font-body">
                    {internship.shortDescription}
                  </p>
                  
                  <!-- Key Skills Pill Indicators -->
                  <div class="space-y-2 pt-2">
                    <div class="text-[10px] font-bold text-slate-400 uppercase tracking-wider">Skills Covered</div>
                    <div class="flex flex-wrap gap-1.5">
                      {(internship.learnItems || []).slice(0, 3).map(skill => {
                        // Extract first 2-3 words of learn items to fit as tags
                        const shortSkill = skill.split(' ').slice(0, 2).join(' ').replace(/,/g, '');
                        return (
                          <span class="px-2.5 py-1 bg-slate-100 text-slate-600 text-[11px] font-bold rounded-lg border border-slate-200/50 hover:bg-slate-200/40 transition-colors">
                            {shortSkill}
                          </span>
                        );
                      })}
                      {(internship.learnItems || []).length > 3 && (
                        <span class="px-2.5 py-1 bg-secondary/5 text-secondary text-[11px] font-bold rounded-lg border border-secondary/10">
                          +{internship.learnItems.length - 3} More
                        </span>
                      )}
                    </div>
                  </div>
                </div>
              </div>

              <!-- Card Action CTA Buttons -->
              <div class="p-6 pt-0">
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-2.5">
                  <a 
                    href={`/internships/${internship.id}`} 
                    class="flex items-center justify-center h-11 px-4 rounded-xl border-2 border-primary text-primary font-bold text-center text-xs hover:bg-primary hover:text-white transition-all duration-300 whitespace-nowrap font-headline"
                  >
                    View Details
                  </a>
                  <a 
                    href="/register" 
                    class="flex items-center justify-center h-11 px-4 rounded-xl btn-brand-gradient text-white font-bold text-center text-xs transition-all duration-300 whitespace-nowrap shadow-md font-headline"
                  >
                    Register Now
                  </a>
                </div>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Client-side Interactive Search & Filtering Javascript -->
  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const searchInput = document.getElementById('search-input');
      const filterPills = document.querySelectorAll('.filter-pill');
      const cards = document.querySelectorAll('.internship-card');
      const noResults = document.getElementById('no-results');
      const resetSearch = document.getElementById('reset-search');
      const grid = document.getElementById('internships-grid');

      let currentQuery = '';
      let currentFilter = 'all';

      function applyFilter() {
        let visibleCount = 0;
        let visibleIndex = 0;

        cards.forEach(card => {
          const category = card.getAttribute('data-category');
          const searchKeywords = card.getAttribute('data-search') || '';
          
          const matchesSearch = !currentQuery || searchKeywords.includes(currentQuery);
          const matchesCategory = currentFilter === 'all' || category === currentFilter;

          if (matchesSearch && matchesCategory) {
            card.style.display = 'flex';
            // Stagger animation
            card.style.opacity = '0';
            card.style.transform = 'translateY(15px)';
            card.style.transition = 'none';
            
            const currentIdx = visibleIndex;
            setTimeout(() => {
              card.style.transition = 'opacity 0.4s cubic-bezier(0.16, 1, 0.3, 1), transform 0.4s cubic-bezier(0.16, 1, 0.3, 1)';
              card.style.opacity = '1';
              card.style.transform = 'translateY(0)';
            }, 30 + currentIdx * 45);
            
            visibleIndex++;
            visibleCount++;
          } else {
            card.style.display = 'none';
          }
        });

        if (visibleCount === 0) {
          noResults.classList.remove('hidden');
          grid.style.display = 'none';
        } else {
          noResults.classList.add('hidden');
          grid.style.display = 'grid';
        }
      }

      // Input Event
      if (searchInput) {
        searchInput.addEventListener('input', (e) => {
          currentQuery = e.target.value.toLowerCase().trim();
          applyFilter();
        });
      }

      // Pill Click Events
      filterPills.forEach(pill => {
        pill.addEventListener('click', () => {
          // Remove active classes
          filterPills.forEach(p => {
            p.classList.remove('active', 'bg-secondary', 'text-white', 'border-secondary', 'shadow-glow-red');
            p.classList.add('bg-white', 'text-slate-600', 'border-slate-200');
          });

          // Set active to clicked
          pill.classList.add('active', 'bg-secondary', 'text-white', 'border-secondary', 'shadow-glow-red');
          pill.classList.remove('bg-white', 'text-slate-600', 'border-slate-200');

          currentFilter = pill.getAttribute('data-filter');
          applyFilter();
        });
      });

      // Reset Button Event
      if (resetSearch) {
        resetSearch.addEventListener('click', () => {
          if (searchInput) searchInput.value = '';
          currentQuery = '';
          
          // Reset pills to "All"
          filterPills.forEach(p => {
            if (p.getAttribute('data-filter') === 'all') {
              p.classList.add('active', 'bg-secondary', 'text-white', 'border-secondary', 'shadow-glow-red');
              p.classList.remove('bg-white', 'text-slate-600', 'border-slate-200');
            } else {
              p.classList.remove('active', 'bg-secondary', 'text-white', 'border-secondary', 'shadow-glow-red');
              p.classList.add('bg-white', 'text-slate-600', 'border-slate-200');
            }
          });
          currentFilter = 'all';
          applyFilter();
        });
      }
    });
  </script>
</Layout>

