---
import Layout from '../layouts/Layout.astro';
import { courses } from '../data/courses.js';
---

<Layout title="Job-Oriented Courses - Margdarshak Shikshan Sansthan" description="Explore our 6 job-oriented courses with a unique 100% fee refund opportunity. Tally, GST, Web Development, DCA, ITR and more.">
  
  <!-- Page Header -->
  <section class="hero-gradient text-white py-16">
    <div class="max-w-7xl mx-auto px-6 md:px-8 text-center space-y-4">
      <div class="inline-block bg-white/10 px-4 py-1.5 rounded-full text-xs font-bold uppercase tracking-wider">
        Skill Development Programs
      </div>
      <h1 class="text-3xl md:text-5xl font-headline font-black">
        Our Job-Oriented Courses
      </h1>
      <p class="text-slate-300 max-w-2xl mx-auto text-base md:text-lg">
        Acquire professional computer and financial skillsets at pocket-friendly pricing, backed by our 100% attendance fee refund guarantee.
      </p>
    </div>
  </section>

  <!-- Refund Highlight Notice -->
  <section class="bg-success/10 border-b border-success/20 py-6">
    <div class="max-w-7xl mx-auto px-6 md:px-8 flex flex-col sm:flex-row items-center justify-between gap-4">
      <div class="flex items-center gap-3">
        <span class="material-symbols-outlined text-success text-3xl font-bold">savings</span>
        <div>
          <h4 class="font-bold text-slate-800 text-sm md:text-base">100% Attendance Fee Refund Opportunity</h4>
          <p class="text-slate-600 text-xs md:text-sm">Achieve 90%+ attendance & complete your projects to get your entire fees back.</p>
        </div>
      </div>
      <a href="/register" class="bg-success hover:bg-emerald-600 text-white font-bold text-xs px-5 py-2.5 rounded-lg transition-all shrink-0">
        Check My Eligibility
      </a>
    </div>
  </section>

  <!-- Courses Grid -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-6 md:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {courses.map(course => (
          <div class="group bg-white border border-slate-200 rounded-2xl overflow-hidden hover:border-primary/30 hover:shadow-xl transition-all duration-300 flex flex-col justify-between">
            <div>
              <div class="h-48 overflow-hidden relative bg-slate-100">
                <img alt={course.name} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" src={course.image} />
                <div class="absolute top-4 right-4 bg-[#d9383a] text-white text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wider">
                  ₹1,000 / month
                </div>
              </div>
              <div class="p-6 space-y-4">
                <div class="flex items-center gap-2 text-secondary font-bold text-sm">
                  <span class="material-symbols-outlined text-sm">schedule</span> Duration: {course.duration}
                </div>
                <h3 class="text-xl font-bold text-primary group-hover:text-secondary transition-colors">
                  {course.name}
                </h3>
                <p class="text-slate-600 text-sm leading-relaxed line-clamp-3">
                  {course.shortDescription}
                </p>
                
                <!-- Tags -->
                <div class="flex flex-wrap gap-1.5 pt-2">
                  {course.tags.map(tag => (
                    <span class="px-2.5 py-1 bg-slate-100 text-slate-600 text-xs font-semibold rounded-md">
                      {tag}
                    </span>
                  ))}
                </div>

                <!-- Refund Notice -->
                <div class="bg-success/5 border border-success/15 p-3 rounded-lg flex items-start gap-2.5 mt-2">
                  <span class="material-symbols-outlined text-success text-lg shrink-0 mt-0.5">verified_user</span>
                  <span class="text-xs text-slate-700 leading-normal">
                    <strong>90%+ attendance = 100% fee refund opportunity</strong>. Ensure regular attendance to study for free.
                  </span>
                </div>
              </div>
            </div>

            <!-- CTA Buttons -->
            <div class="p-6 pt-0 space-y-3">
              <div class="grid grid-cols-2 gap-2">
                <a href={`/courses/${course.id}`} class="py-2.5 rounded-lg border-2 border-primary text-primary font-bold text-center text-xs hover:bg-primary hover:text-white transition-all">
                  View Details
                </a>
                <a href="/register" class="py-2.5 rounded-lg bg-[#d9383a] text-white font-bold text-center text-xs hover:bg-[#c12f31] transition-all">
                  Register Now
                </a>
              </div>
              <a 
                href={`https://wa.me/919229025257?text=Hi,%20I'm%20interested%20in%20enrolling%20for%20the%20${encodeURIComponent(course.name)}%20course.`} 
                target="_blank" 
                class="block w-full py-2 bg-success text-white rounded-lg text-center font-bold text-xs hover:bg-emerald-600 transition-all flex items-center justify-center gap-1.5"
              >
                <span class="material-symbols-outlined text-sm">chat</span> Explore in App / WhatsApp
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

</Layout>
