---
import Layout from '../layouts/Layout.astro';
import { getCourses, getInternships } from '../data/db.js';

// Get 3 popular courses and 3 popular internships for previews
const allCourses = await getCourses();
const popularCourses = allCourses.slice(0, 3); // DCA, Web Dev, Digital Marketing
const allInternships = await getInternships();
const popularInternships = allInternships.filter(item => 
  ["web-development", "gst-filing", "ai-tools"].includes(item.id)
);
---

<Layout 
  title="Margdarshak Shikshan Sansthan — Job-Ready Courses & Internships in Darbhanga | 100% Fee Refund" 
  description="Margdarshak Shikshan Sansthan offers affordable, job-oriented courses in Web Development, Tally, GST, Digital Marketing & more in Darbhanga, Bihar. 100% fee refund with 90%+ attendance. Enroll for just ₹1,000/month."
  ogImage="/assets/new_hero_illustration.png"
  jsonLd={{
    "@context": "https://schema.org",
    "@type": "ItemList",
    "name": "Popular Courses at Margdarshak",
    "itemListElement": popularCourses.map((course, i) => ({
      "@type": "ListItem",
      "position": i + 1,
      "item": {
        "@type": "Course",
        "name": course.name,
        "description": course.shortDescription,
        "provider": {
          "@type": "Organization",
          "name": "Margdarshak Shikshan Sansthan"
        }
      }
    }))
  }}
>
  
  <!-- Hero Section -->
  <section class="relative hero-gradient pt-6 pb-10 md:pt-14 md:pb-20 lg:pt-16 lg:pb-24 overflow-hidden text-white flex items-center">
    <!-- Glowing background decorative blobs - limited to brand red and soft orange/gold -->
    <div class="glow-blob bg-secondary w-96 h-96 -top-20 -left-20 opacity-25 animate-pulse-glow" style="filter: blur(130px);" aria-hidden="true"></div>
    <div class="glow-blob bg-accent w-96 h-96 bottom-10 right-10 opacity-20 animate-pulse-glow" style="filter: blur(130px); animation-delay: 2.5s;" aria-hidden="true"></div>

    <div class="max-w-[1440px] mx-auto px-4 md:px-6 grid grid-cols-1 lg:grid-cols-[45%_55%] gap-8 lg:gap-16 items-center relative z-10 w-full">
      
      <!-- Hero Left Text Content (45% Visual Weight) -->
      <div class="space-y-5 lg:space-y-6 lg:max-w-xl reveal reveal-slide-up">
        <div class="inline-flex items-center gap-2 bg-white/5 border border-white/10 px-4 py-2 rounded-full backdrop-blur-md shadow-glass animate-float-slow">
          <span class="w-2 h-2 rounded-full bg-accent animate-ping"></span>
          <span class="text-accent font-headline font-bold text-xs tracking-wider uppercase">LEARN • INTERN • GROW</span>
        </div>
        
        <h1 class="text-3xl sm:text-5xl lg:text-5xl xl:text-6xl font-display font-black leading-[1.15] tracking-tight">
          Padhega Bharat, <br />
          <span class="text-gradient-purple-orange">Badhega Bharat</span>
        </h1>
        
        <p class="text-base text-slate-300 leading-relaxed font-light max-w-lg">
          Industry-ready certification programs with a unique <span class="font-semibold text-secondary dark:text-purpleglow border-b border-secondary/30 pb-0.5">100% Fee Refund guarantee</span>. Join India's most student-friendly learning ecosystem in Darbhanga.
        </p>
        
        <!-- Key Perks cards -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 pt-1">
          <div class="flex items-center gap-3 bg-white/5 py-2.5 px-3.5 rounded-xl border border-white/10 hover:border-white/20 hover:bg-white/10 transition-all duration-300 shadow-glass group">
            <span class="material-symbols-outlined text-accent text-2xl shrink-0 group-hover:scale-110 transition-transform" style="font-variation-settings: 'FILL' 1;">payments</span>
            <div>
              <p class="text-slate-400 text-[10px] font-bold uppercase tracking-wider">Affordable Fee</p>
              <span class="font-bold text-white text-xs md:text-sm">₹1,000/month fee</span>
            </div>
          </div>
          <div class="flex items-center gap-3 bg-white/5 py-2.5 px-3.5 rounded-xl border border-white/10 hover:border-white/20 hover:bg-white/10 transition-all duration-300 shadow-glass group">
            <span class="material-symbols-outlined text-secondary text-2xl shrink-0 group-hover:scale-110 transition-transform" style="font-variation-settings: 'FILL' 1;">verified_user</span>
            <div>
              <p class="text-slate-400 text-[10px] font-bold uppercase tracking-wider">Refund Trust</p>
              <span class="font-bold text-white text-xs md:text-sm">90%+ Attendance = 100% Refund</span>
            </div>
          </div>
        </div>
        
        <!-- CTA buttons -->
        <div class="flex flex-col sm:flex-row gap-3 pt-3">
          <a class="btn-brand-gradient text-white px-6 h-12 rounded-xl font-bold text-sm lg:text-base text-center flex items-center justify-center gap-2 whitespace-nowrap w-full sm:w-auto transition-all duration-300 hover:scale-105 shadow-premium" href="/courses">
            Explore Courses
            <span class="material-symbols-outlined text-lg">arrow_forward</span>
          </a>
          <a class="bg-white/5 hover:bg-white/10 border border-white/20 hover:border-white/30 text-white px-6 h-12 rounded-xl font-bold text-sm lg:text-base text-center flex items-center justify-center gap-2 whitespace-nowrap w-full sm:w-auto transition-all duration-300 hover:scale-105 shadow-glass" href="/internships">
            Apply for Internship
          </a>
          <a class="flex items-center justify-center gap-2 bg-[#071426] hover:bg-[#0c1c38] border border-accent/20 hover:border-accent/40 text-white px-6 h-12 rounded-xl font-bold text-sm lg:text-base text-center transition-all duration-300 w-full sm:w-auto hover:scale-105 hover:shadow-glow-orange whitespace-nowrap" href="https://play.google.com/store/apps/details?id=co.varys.shacc" target="_blank" rel="noopener noreferrer" aria-label="Download App on Google Play Store">
            <!-- Google Play Icon (Bootstrap SVG) -->
            <svg class="w-4 h-4 md:w-5 md:h-5 shrink-0" fill="currentColor" viewBox="0 0 16 16">
              <path d="M14.222 9.374c1.037-.61 1.037-2.137 0-2.748L11.528 5.04 8.32 8l3.207 2.96 2.694-1.586Zm-3.595 2.116L7.583 8.68 1.03 14.73c.201 1.029 1.36 1.61 2.303 1.055l7.294-4.295ZM1 13.396V2.603L6.847 8 1 13.396ZM1.03 1.27C1.984.716 3.143 1.297 3.344 2.326L7.583 7.32 10.627 5.5l-3.044 2.82L1.03 1.27Z"/>
            </svg>
            Download App
          </a>
        </div>
      </div>
      
      <!-- Hero Right Image Section with Integrated composition (55% Visual Weight) -->
      <div class="relative mt-8 lg:mt-0 flex justify-center items-center w-full">
        <!-- Soft, subtle premium glow backing (blend colors Red, Orange, Golden Yellow) -->
        <div class="absolute w-[85%] h-[85%] top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 bg-gradient-to-tr from-secondary/15 via-brandOrange/10 to-accent/15 rounded-full opacity-30 blur-[80px] lg:blur-[120px] pointer-events-none z-0"></div>
        
        <!-- Main Image Wrapper (No borders, transparent presentation, auto height, landscape) -->
        <div class="relative z-10 w-full max-w-[500px] md:max-w-[600px] lg:max-w-none animate-float-slow reveal reveal-scale" style="transition-delay: 150ms">
          <picture>
            <source srcset="/assets/new_hero_illustration.webp" type="image/webp" />
            <img 
              alt="Margdarshak Learning Ecosystem — students in classroom with laptop" 
              class="w-full h-auto object-contain select-none" 
              src="/assets/new_hero_illustration.png" 
              loading="eager" 
              fetchpriority="high" 
              decoding="async"
              width="800"
              height="600"
            />
          </picture>
        </div>
      </div>

    </div>
  </section>

  <!-- Key Features / Why Choose Us Section -->
  <div class="relative z-20 max-w-[1440px] mx-auto px-4 md:px-6 mt-8 md:mt-16 mb-8 animate-on-scroll">
    <div class="bg-[#071426] border border-white/10 p-4 sm:p-6 md:p-8 rounded-2xl shadow-premium">

      <!-- Section Label -->
      <div class="text-center mb-6">
        <span class="inline-flex items-center gap-2 bg-white/5 border border-white/10 px-4 py-1.5 rounded-full text-[10px] font-bold uppercase tracking-widest text-slate-300">
          <span class="material-symbols-outlined text-accent text-sm" style="font-variation-settings: 'FILL' 1;">star</span>
          Why Choose Us
        </span>
      </div>

      <!-- Feature Cards Grid -->
      <div class="grid grid-cols-1 xs:grid-cols-2 md:grid-cols-4 gap-3 sm:gap-4">

        <!-- Practical Training -->
        <div class="group flex flex-col items-center text-center gap-3 p-4 sm:p-5 rounded-2xl bg-white/5 border border-white/10 hover:border-secondary/40 hover:bg-white/10 transition-all duration-300 hover:-translate-y-1 shadow-glass">
          <div class="w-11 h-11 sm:w-12 sm:h-12 rounded-xl bg-secondary/10 text-secondary flex items-center justify-center group-hover:scale-110 group-hover:bg-secondary/20 transition-all duration-300 shadow-inner">
            <span class="material-symbols-outlined text-xl sm:text-2xl" style="font-variation-settings: 'FILL' 1;">psychology</span>
          </div>
          <div class="space-y-1">
            <p class="text-white font-bold text-sm sm:text-base leading-tight tracking-tight">Practical Training</p>
            <p class="text-slate-400 text-[10px] sm:text-xs font-medium uppercase tracking-wider">Hands-on Learning</p>
          </div>
        </div>

        <!-- Hybrid Learning -->
        <div class="group flex flex-col items-center text-center gap-3 p-4 sm:p-5 rounded-2xl bg-white/5 border border-white/10 hover:border-accent/40 hover:bg-white/10 transition-all duration-300 hover:-translate-y-1 shadow-glass">
          <div class="w-11 h-11 sm:w-12 sm:h-12 rounded-xl bg-accent/10 text-accent flex items-center justify-center group-hover:scale-110 group-hover:bg-accent/20 transition-all duration-300 shadow-inner">
            <span class="material-symbols-outlined text-xl sm:text-2xl" style="font-variation-settings: 'FILL' 1;">laptop_mac</span>
          </div>
          <div class="space-y-1">
            <p class="text-white font-bold text-sm sm:text-base leading-tight tracking-tight">Hybrid Learning</p>
            <p class="text-slate-400 text-[10px] sm:text-xs font-medium uppercase tracking-wider">Classroom & Online</p>
          </div>
        </div>

        <!-- Career Support -->
        <div class="group flex flex-col items-center text-center gap-3 p-4 sm:p-5 rounded-2xl bg-white/5 border border-white/10 hover:border-secondary/40 hover:bg-white/10 transition-all duration-300 hover:-translate-y-1 shadow-glass">
          <div class="w-11 h-11 sm:w-12 sm:h-12 rounded-xl bg-secondary/10 text-secondary flex items-center justify-center group-hover:scale-110 group-hover:bg-secondary/20 transition-all duration-300 shadow-inner">
            <span class="material-symbols-outlined text-xl sm:text-2xl" style="font-variation-settings: 'FILL' 1;">handshake</span>
          </div>
          <div class="space-y-1">
            <p class="text-white font-bold text-sm sm:text-base leading-tight tracking-tight">Career Support</p>
            <p class="text-slate-400 text-[10px] sm:text-xs font-medium uppercase tracking-wider">Guidance & Mentorship</p>
          </div>
        </div>

        <!-- Internship Programs -->
        <div class="group flex flex-col items-center text-center gap-3 p-4 sm:p-5 rounded-2xl bg-white/5 border border-white/10 hover:border-accent/40 hover:bg-white/10 transition-all duration-300 hover:-translate-y-1 shadow-glass">
          <div class="w-11 h-11 sm:w-12 sm:h-12 rounded-xl bg-accent/10 text-accent flex items-center justify-center group-hover:scale-110 group-hover:bg-accent/20 transition-all duration-300 shadow-inner">
            <span class="material-symbols-outlined text-xl sm:text-2xl" style="font-variation-settings: 'FILL' 1;">work</span>
          </div>
          <div class="space-y-1">
            <p class="text-white font-bold text-sm sm:text-base leading-tight tracking-tight">Internship Programs</p>
            <p class="text-slate-400 text-[10px] sm:text-xs font-medium uppercase tracking-wider">Real Industry Exposure</p>
          </div>
        </div>

      </div>
    </div>
  </div>



  <!-- Institute Introduction & Bento Grid Section -->
  <section class="py-24 bg-slate-50 dark:bg-slate-950 relative overflow-hidden">
    <div class="glow-blob bg-secondary/5 w-96 h-96 top-1/4 -right-20 opacity-15" style="filter: blur(120px);"></div>
    <div class="glow-blob bg-accent/5 w-96 h-96 bottom-10 -left-20 opacity-15" style="filter: blur(120px);"></div>

    <div class="max-w-[1440px] mx-auto px-4 md:px-6">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-center">
        
        <!-- Text intro side -->
        <div class="lg:col-span-5 space-y-6">
          <div class="inline-block bg-secondary/10 text-secondary px-4 py-1.5 rounded-full font-bold text-xs uppercase tracking-wider border border-secondary/15">
            About Margdarshak
          </div>
          <h2 class="text-3xl md:text-5xl font-headline font-black text-primary dark:text-white leading-tight tracking-tight">
            Empowering Bharat Through Skilled Education
          </h2>
          <div class="space-y-4 text-slate-600 dark:text-slate-300 leading-relaxed text-base font-light">
            <p>
              Margdarshak Shikshan Sansthan is Darbhanga’s premier educational institute dedicated to bridging the gap between theoretical knowledge and real-world employment. With a curriculum engineered by industry experts, we provide students with hands-on practice in computerized accounting, programming, tax filings, and digital marketing.
            </p>
            <p>
              Our unique hybrid learning infrastructure allows students to study in our state-of-the-art offline computer labs or attend live online classes, backed by our core mission: providing premium education accessible to everyone.
            </p>
          </div>
          <div class="pt-4">
            <a href="/about" class="inline-flex items-center gap-2 font-bold text-secondary hover:text-secondary/95 group transition-colors duration-300">
              Learn More About Our Mission 
              <span class="material-symbols-outlined text-lg transition-transform duration-300 group-hover:translate-x-1.5">arrow_forward</span>
            </a>
          </div>
        </div>
        
        <!-- Bento Grid Side (Issue 4: Same rounded-2xl and shadow-premium) -->
        <div class="lg:col-span-7 grid grid-cols-1 xs:grid-cols-2 gap-3 sm:gap-6">
          
          <!-- Card 1: Govt. Registered -->
          <div class="glass-card-premium p-3.5 xs:p-4 sm:p-8 rounded-2xl border-slate-200/60 dark:border-slate-800 shadow-premium hover-lift hover:shadow-premium-hover transition-all duration-300 flex flex-col justify-between min-h-[160px] xs:min-h-[185px] sm:min-h-[220px] reveal reveal-slide-up" style="transition-delay: 50ms">
            <div class="w-9 h-9 sm:w-12 sm:h-12 bg-secondary/10 text-secondary rounded-xl flex items-center justify-center mb-4 sm:mb-6 shadow-sm">
              <span class="material-symbols-outlined text-lg sm:text-2xl font-bold">workspace_premium</span>
            </div>
            <div>
              <h3 class="font-bold text-xs xs:text-sm sm:text-xl text-primary dark:text-white mb-1 sm:mb-2 tracking-tight">Government Registered</h3>
              <p class="text-slate-500 dark:text-slate-400 text-[10px] xs:text-[11px] sm:text-sm leading-relaxed font-light">Certificates registered under the Ministry of Corporate Affairs, Govt. of India, recognized nationwide.</p>
            </div>
          </div>
          
          <!-- Card 2: Expert Mentorship -->
          <div class="glass-card-premium p-3.5 xs:p-4 sm:p-8 rounded-2xl border-slate-200/60 dark:border-slate-800 shadow-premium hover-lift hover:shadow-premium-hover transition-all duration-300 flex flex-col justify-between min-h-[160px] xs:min-h-[185px] sm:min-h-[220px] reveal reveal-slide-up" style="transition-delay: 150ms">
            <div class="w-9 h-9 sm:w-12 sm:h-12 bg-accent/10 text-accent rounded-xl flex items-center justify-center mb-4 sm:mb-6 shadow-sm">
              <span class="material-symbols-outlined text-lg sm:text-2xl font-bold">diversity_3</span>
            </div>
            <div>
              <h3 class="font-bold text-xs xs:text-sm sm:text-xl text-primary dark:text-white mb-1 sm:mb-2 tracking-tight">Expert Mentorship</h3>
              <p class="text-slate-500 dark:text-slate-400 text-[10px] xs:text-[11px] sm:text-sm leading-relaxed font-light">Learn from experienced tax advisors, certified accountants, and software developers.</p>
            </div>
          </div>
          
          <!-- Card 3: Practical Focus -->
          <div class="glass-card-premium p-3.5 xs:p-4 sm:p-8 rounded-2xl border-slate-200/60 dark:border-slate-800 shadow-premium hover-lift hover:shadow-premium-hover transition-all duration-300 flex flex-col justify-between min-h-[160px] xs:min-h-[185px] sm:min-h-[220px] reveal reveal-slide-up" style="transition-delay: 250ms">
            <div class="w-9 h-9 sm:w-12 sm:h-12 bg-secondary/10 text-secondary rounded-xl flex items-center justify-center mb-4 sm:mb-6 shadow-sm">
              <span class="material-symbols-outlined text-lg sm:text-2xl font-bold">handshake</span>
            </div>
            <div>
              <h3 class="font-bold text-xs xs:text-sm sm:text-xl text-primary dark:text-white mb-1 sm:mb-2 tracking-tight">Practical-First Focus</h3>
              <p class="text-slate-500 dark:text-slate-400 text-[10px] xs:text-[11px] sm:text-sm leading-relaxed font-light">Every program includes mandatory live-project training and client interaction modules.</p>
            </div>
          </div>
          
          <!-- Card 4: Refund Integrity -->
          <div class="glass-card-premium p-3.5 xs:p-4 sm:p-8 rounded-2xl border-slate-200/60 dark:border-slate-800 shadow-premium hover-lift hover:shadow-premium-hover transition-all duration-300 flex flex-col justify-between min-h-[160px] xs:min-h-[185px] sm:min-h-[220px] reveal reveal-slide-up" style="transition-delay: 350ms">
            <div class="w-9 h-9 sm:w-12 sm:h-12 bg-secondary/10 text-secondary rounded-xl flex items-center justify-center mb-4 sm:mb-6 shadow-sm">
              <span class="material-symbols-outlined text-lg sm:text-2xl font-bold">assignment_turned_in</span>
            </div>
            <div>
              <h3 class="font-bold text-xs xs:text-sm sm:text-xl text-primary dark:text-white mb-1 sm:mb-2 tracking-tight">100% Refund Integrity</h3>
              <p class="text-slate-500 dark:text-slate-400 text-[10px] xs:text-[11px] sm:text-sm leading-relaxed font-light">Our trust policy: stay dedicated, keep 90% attendance, and study for free.</p>
            </div>
          </div>
          
        </div>
      </div>
    </div>
  </section>


  <!-- Highlighted 100% Fee Refund Section -->
  <section class="py-12 bg-white dark:bg-slate-900/40 relative overflow-hidden">
    <div class="max-w-[1440px] mx-auto px-4 md:px-6">
      
      <!-- Gradient Mesh Core Container -->
      <div class="relative bg-gradient-to-tr from-primary to-slate-950 rounded-2xl p-8 md:p-16 text-white overflow-hidden shadow-premium border border-white/10 flex flex-col lg:flex-row items-center justify-between gap-12">
        <!-- Accent Glow Blobs -->
        <div class="absolute -right-24 -bottom-24 w-96 h-96 bg-secondary/15 rounded-full blur-3xl pointer-events-none"></div>
        <div class="absolute -left-20 -top-20 w-80 h-80 bg-accent/10 rounded-full blur-3xl pointer-events-none"></div>

        <!-- Left narrative info -->
        <div class="relative z-10 max-w-2xl space-y-6">
          <div class="inline-block bg-white/10 text-accent font-bold text-xs px-4 py-1.5 rounded-full uppercase tracking-wider border border-white/15">
            Unique Learning Opportunity
          </div>
          <h2 class="text-3xl md:text-5xl font-headline font-black leading-tight">
            Education is FREE if you are DEDICATED!
          </h2>
          <p class="text-slate-300 text-base md:text-lg leading-relaxed font-light">
            At Margdarshak Shikshan Sansthan, we reward sincerity. Maintain a minimum of <strong class="text-white font-bold">90% attendance</strong> during your course and successfully complete the <strong class="text-white font-bold">1-month internship</strong> program to receive a <strong class="text-white font-bold">100% refund</strong> of your entire tuition fees. No catches, no hidden conditions.
          </p>
          
          <!-- Steps block -->
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 pt-4">
            <div class="flex items-center gap-3 bg-white/5 border border-white/10 p-3.5 rounded-xl shadow-glass">
              <span class="material-symbols-outlined text-secondary font-bold" style="font-variation-settings: 'FILL' 1;">check_circle</span>
              <span class="text-sm font-semibold text-slate-200">90%+ Attendance</span>
            </div>
            <div class="flex items-center gap-3 bg-white/5 border border-white/10 p-3.5 rounded-xl shadow-glass">
              <span class="material-symbols-outlined text-secondary font-bold" style="font-variation-settings: 'FILL' 1;">check_circle</span>
              <span class="text-sm font-semibold text-slate-200">Project Submission</span>
            </div>
            <div class="flex items-center gap-3 bg-white/5 border border-white/10 p-3.5 rounded-xl shadow-glass">
              <span class="material-symbols-outlined text-secondary font-bold" style="font-variation-settings: 'FILL' 1;">check_circle</span>
              <span class="text-sm font-semibold text-slate-200">Internship Completion</span>
            </div>
          </div>
        </div>
        
        <!-- Right Action Card overlay -->
        <div class="relative z-10 glass-card-premium bg-white/5 backdrop-blur-2xl border border-white/15 p-8 rounded-2xl text-center w-full lg:w-80 shrink-0 shadow-glass flex flex-col items-center">
          <div class="w-16 h-16 rounded-full bg-secondary/10 text-secondary flex items-center justify-center mb-4">
            <span class="material-symbols-outlined text-4xl text-white" style="font-variation-settings: 'FILL' 1;">currency_exchange</span>
          </div>
          <div class="text-5xl font-black text-white mb-2 leading-none">100%</div>
          <div class="text-lg font-bold text-slate-200 mb-4 tracking-tight">Refund Opportunity</div>
          <div class="w-full border-t border-white/10 pt-4 mb-6 text-[10px] text-slate-400 font-bold tracking-wide uppercase">
            Available on all Courses & Internships
          </div>
          <a href="/register" class="block w-full bg-white hover:bg-slate-100 text-primary hover:scale-[1.03] transition-all py-3.5 rounded-xl font-bold text-sm text-center shadow-premium">
            Register & Apply Now
          </a>
        </div>
      </div>
      
    </div>
  </section>

  <!-- Popular Courses Preview Section -->
  <section class="py-24 bg-slate-50 dark:bg-slate-950 relative overflow-hidden">
    <div class="glow-blob bg-secondary/5 w-[500px] h-[500px] top-10 left-10 opacity-20" style="filter: blur(120px);"></div>
    
    <div class="max-w-[1440px] mx-auto px-4 md:px-6">
      
      <!-- Course Section Title -->
      <div class="flex flex-col md:flex-row justify-between items-end mb-16 gap-6 relative z-10">
        <div>
          <div class="inline-block bg-secondary/10 text-secondary px-4 py-1.5 rounded-full font-bold text-xs uppercase tracking-wider border border-secondary/15 mb-3">
            Industry Hotspots
          </div>
          <h2 class="text-3xl md:text-5xl font-headline font-black text-primary dark:text-white leading-none tracking-tight">Job-Oriented Courses</h2>
          <p class="text-slate-500 dark:text-slate-400 mt-3 text-base font-light">Acquire hands-on expertise with Darbhanga’s most in-demand curriculum.</p>
        </div>
        <a class="hidden md:inline-flex items-center gap-2 font-bold text-secondary hover:text-secondary/95 group transition-colors duration-300 shrink-0 border-b border-transparent hover:border-secondary pb-1" href="/courses">
          View All Courses 
          <span class="material-symbols-outlined text-lg transition-transform duration-300 group-hover:translate-x-1.5">arrow_forward</span>
        </a>
      </div>

