---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { getCourses, getInternships, getStudents } from '../../data/db.js';

export const prerender = false;

// Fetch current stats from database
const courses = getCourses();
const internships = getInternships();
const students = getStudents();

// Calculate stats
const totalCourses = courses.length;
const totalInternships = internships.length;
const totalStudents = students.length;

// Recent registrations in the last 7 days
const recentStudentsCount = students.filter(student => {
  if (!student.date) return false;
  const registrationDate = new Date(student.date);
  const diffTime = Date.now() - registrationDate.getTime();
  const diffDays = diffTime / (1000 * 60 * 60 * 24);
  return diffDays >= 0 && diffDays <= 7;
}).length;

// Get latest 5 registrations
const latestRegistrations = [...students]
  .sort((a, b) => new Date(b.date) - new Date(a.date))
  .slice(0, 5);

// Format date helper
function formatDate(dateStr) {
  if (!dateStr) return 'N/A';
  return new Date(dateStr).toLocaleDateString('en-IN', {
    day: '2-digit',
    month: 'short',
    year: 'numeric'
  });
}
---

<AdminLayout title="Dashboard - Margdarshak Admin" activeTab="dashboard">
  <div class="space-y-8">
    
    <!-- Welcome Section -->
    <div class="glass-card-premium p-6 sm:p-8 rounded-3xl border border-slate-200/60 shadow-sm flex flex-col md:flex-row md:items-center justify-between gap-6 relative overflow-hidden">
      <!-- Decorative background glow inside card -->
      <div class="absolute right-0 top-0 w-64 h-64 bg-gradient-to-br from-[#FF7043]/10 to-[#FFB300]/10 rounded-full blur-3xl pointer-events-none -z-10"></div>
      
      <div class="space-y-2 relative z-10">
        <h3 class="text-2xl md:text-3xl font-headline font-extrabold text-[#071426] tracking-tight">
          Welcome back, <span class="bg-gradient-to-r from-[#E53935] to-[#FF7043] bg-clip-text text-fill-transparent -webkit-background-clip: text; -webkit-text-fill-color: transparent;">Admin</span>!
        </h3>
        <p class="text-xs md:text-sm text-slate-400 font-semibold leading-relaxed max-w-xl">
          Here's the current summary of Margdarshak Shikshan Sansthan registrations, active courses, and internship applications.
        </p>
      </div>
      
      <div class="flex flex-wrap gap-3 shrink-0 relative z-10">
        <a href="/admin/courses" class="px-4 py-2.5 bg-slate-50 hover:bg-slate-100 text-[#071426] border border-slate-200 rounded-xl font-headline font-bold text-xs transition-all flex items-center gap-1.5 shadow-sm hover:scale-[1.02]">
          <span class="material-symbols-outlined text-base">add_circle</span> Add Course
        </a>
        <a href="/admin/students" class="px-4 py-2.5 btn-brand-gradient text-white rounded-xl font-headline font-bold text-xs transition-all flex items-center gap-1.5 shadow-md shadow-[#E53935]/15">
          <span class="material-symbols-outlined text-base">group</span> View Students
        </a>
      </div>
    </div>

    <!-- Summary Cards -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      
      <!-- Card 1: Total Courses -->
      <div class="glass-card-premium p-6 rounded-3xl border border-slate-200/60 shadow-sm flex items-center gap-5 hover:scale-[1.03] transition-all duration-300 hover:shadow-md hover:border-[#FF7043]/30">
        <div class="w-12 h-12 rounded-xl bg-[#071426]/5 border border-[#071426]/10 flex items-center justify-center text-[#071426]">
          <span class="material-symbols-outlined text-2xl font-bold">menu_book</span>
        </div>
        <div class="space-y-0.5">
          <span class="text-[10px] font-headline font-extrabold text-slate-400 uppercase tracking-wider block">Total Courses</span>
          <div class="text-2xl font-headline font-black text-[#071426] leading-none">{totalCourses}</div>
          <span class="text-[9px] text-[#FF7043] font-bold block">Active Training Tracks</span>
        </div>
      </div>

      <!-- Card 2: Total Internships -->
      <div class="glass-card-premium p-6 rounded-3xl border border-slate-200/60 shadow-sm flex items-center gap-5 hover:scale-[1.03] transition-all duration-300 hover:shadow-md hover:border-[#FF7043]/30">
        <div class="w-12 h-12 rounded-xl bg-[#E53935]/5 border border-[#E53935]/10 flex items-center justify-center text-[#E53935]">
          <span class="material-symbols-outlined text-2xl font-bold">work</span>
        </div>
        <div class="space-y-0.5">
          <span class="text-[10px] font-headline font-extrabold text-slate-400 uppercase tracking-wider block">Total Internships</span>
          <div class="text-2xl font-headline font-black text-[#071426] leading-none">{totalInternships}</div>
          <span class="text-[9px] text-[#FF7043] font-bold block">Practical Programs</span>
        </div>
      </div>

      <!-- Card 3: Total Registrations -->
      <div class="glass-card-premium p-6 rounded-3xl border border-slate-200/60 shadow-sm flex items-center gap-5 hover:scale-[1.03] transition-all duration-300 hover:shadow-md hover:border-[#FF7043]/30">
        <div class="w-12 h-12 rounded-xl bg-emerald-50 border border-emerald-100 flex items-center justify-center text-success">
          <span class="material-symbols-outlined text-2xl font-bold">group</span>
        </div>
        <div class="space-y-0.5">
          <span class="text-[10px] font-headline font-extrabold text-slate-400 uppercase tracking-wider block">Total Registrations</span>
          <div class="text-2xl font-headline font-black text-[#071426] leading-none">{totalStudents}</div>
          <span class="text-[9px] text-success font-bold block">Enrollments & Leads</span>
        </div>
      </div>

      <!-- Card 4: Recent Registrations -->
      <div class="glass-card-premium p-6 rounded-3xl border border-slate-200/60 shadow-sm flex items-center gap-5 hover:scale-[1.03] transition-all duration-300 hover:shadow-md hover:border-[#FF7043]/30">
        <div class="w-12 h-12 rounded-xl bg-[#FFB300]/10 border border-[#FFB300]/25 flex items-center justify-center text-[#FFB300]">
          <span class="material-symbols-outlined text-2xl font-bold">person_add</span>
        </div>
        <div class="space-y-0.5">
          <span class="text-[10px] font-headline font-extrabold text-slate-400 uppercase tracking-wider block">Recent (7 Days)</span>
          <div class="text-2xl font-headline font-black text-[#071426] leading-none">{recentStudentsCount}</div>
          <span class="text-[9px] text-[#FFB300] font-extrabold block">New Student Applications</span>
        </div>
      </div>

    </div>

    <!-- Latest Registrations Table Section -->
    <div class="glass-card-premium rounded-3xl border border-slate-200/60 shadow-sm overflow-hidden">
      <div class="px-6 py-5 border-b border-slate-100 flex items-center justify-between">
        <div>
          <h3 class="font-headline font-bold text-base text-[#071426]">Latest Registrations</h3>
          <p class="text-[11px] text-slate-400 font-semibold">Preview of the most recent student applications</p>
        </div>
        <a href="/admin/students" class="text-xs font-headline font-bold text-[#E53935] hover:underline flex items-center gap-1.5 transition-colors">
          View All Students <span class="material-symbols-outlined text-sm font-bold">arrow_forward</span>
        </a>
      </div>

      {latestRegistrations.length === 0 ? (
        <div class="p-12 text-center text-slate-400 space-y-3">
          <span class="material-symbols-outlined text-5xl text-slate-300">group_add</span>
          <p class="text-sm font-semibold">No registrations received yet.</p>
        </div>
      ) : (
        <div>
          <!-- Desktop Table view -->
          <table class="hidden md:table w-full text-left border-collapse">
            <thead>
              <tr class="bg-slate-50/50 border-b border-slate-100 text-[10px] font-headline font-extrabold text-slate-400 uppercase tracking-wider">
                <th class="px-6 py-4">Student Name</th>
                <th class="px-6 py-4">Contact Info</th>
                <th class="px-6 py-4">Selected Program</th>
                <th class="px-6 py-4">Registration Date</th>
                <th class="px-6 py-4">Status</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100/70 text-xs font-medium">
              {latestRegistrations.map(student => (
                <tr class="hover:bg-slate-50/40 transition-colors">
                  <td class="px-6 py-4">
                    <span class="font-headline font-bold text-[#071426] text-sm block">{student.name}</span>
                    <span class="text-[10px] text-slate-400 font-mono tracking-tight">{student.id.substring(0, 8)}...</span>
                  </td>
                  <td class="px-6 py-4 space-y-0.5">
                    <div class="text-slate-600 flex items-center gap-1.5">
                      <span class="material-symbols-outlined text-xs">call</span> {student.mobile}
                    </div>
                    <div class="text-slate-400 flex items-center gap-1.5">
                      <span class="material-symbols-outlined text-xs">mail</span> {student.email}
                    </div>
                  </td>
                  <td class="px-6 py-4">
                    <span class={`inline-block px-2 py-0.5 rounded text-[8px] font-headline font-extrabold uppercase tracking-wider mb-1 ${
                      student.programType === 'course' ? 'bg-[#071426]/5 text-[#071426] border border-[#071426]/10' : 'bg-[#E53935]/5 text-[#E53935] border border-[#E53935]/10'
                    }`}>
                      {student.programType}
                    </span>
                    <div class="font-semibold text-slate-700">{student.programName}</div>
                  </td>
                  <td class="px-6 py-4 text-slate-500 font-semibold">
                    {formatDate(student.date)}
                  </td>
                  <td class="px-6 py-4">
                    <span class={`inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-[10px] font-headline font-extrabold uppercase ${
                      student.status === 'Enrolled' 
                        ? 'bg-emerald-50 text-success' 
                        : student.status === 'Cancelled'
                        ? 'bg-rose-50 text-[#E53935]'
                        : 'bg-amber-50 text-amber-700'
                    }`}>
                      <span class="w-1.5 h-1.5 rounded-full bg-current"></span>
                      {student.status || 'Pending'}
                    </span>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>

          <!-- Mobile Cards view -->
          <div class="block md:hidden divide-y divide-slate-100">
            {latestRegistrations.map(student => (
              <div class="p-5 space-y-4">
                <div class="flex items-start justify-between gap-4">
                  <div>
                    <span class="font-headline font-bold text-[#071426] text-base block">{student.name}</span>
                    <span class="text-[10px] text-slate-400 font-mono tracking-tight">{student.id.substring(0, 8)}...</span>
                  </div>
                  <span class={`inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-[10px] font-headline font-extrabold uppercase ${
                    student.status === 'Enrolled' 
                      ? 'bg-emerald-50 text-success' 
                      : student.status === 'Cancelled'
                      ? 'bg-rose-50 text-[#E53935]'
                      : 'bg-amber-50 text-amber-700'
                  }`}>
                    <span class="w-1.5 h-1.5 rounded-full bg-current"></span>
                    {student.status || 'Pending'}
                  </span>
                </div>

                <div class="grid grid-cols-2 gap-4 text-xs font-semibold">
                  <div class="space-y-1">
                    <span class="text-slate-400 text-[10px] uppercase font-bold tracking-wider block">Selected Program</span>
                    <span class={`inline-block px-2 py-0.5 rounded text-[8px] font-headline font-extrabold uppercase tracking-wider mb-1 ${
                      student.programType === 'course' ? 'bg-[#071426]/5 text-[#071426] border border-[#071426]/10' : 'bg-[#E53935]/5 text-[#E53935] border border-[#E53935]/10'
                    }`}>
                      {student.programType}
                    </span>
                    <div class="text-slate-700 font-semibold">{student.programName}</div>
                  </div>
                  
                  <div class="space-y-1">
                    <span class="text-slate-400 text-[10px] uppercase font-bold tracking-wider block">Registration Date</span>
                    <div class="text-slate-500 font-semibold">{formatDate(student.date)}</div>
                  </div>
                </div>

                <div class="pt-3 border-t border-slate-100/70 flex flex-wrap gap-x-4 gap-y-2 text-xs">
                  <a href={`tel:${student.mobile}`} class="text-slate-600 flex items-center gap-1.5">
                    <span class="material-symbols-outlined text-sm">call</span> {student.mobile}
                  </a>
                  <a href={`mailto:${student.email}`} class="text-slate-400 flex items-center gap-1.5">
                    <span class="material-symbols-outlined text-sm">mail</span> {student.email}
                  </a>
                </div>
              </div>
            ))}
          </div>
        </div>
      )}
    </div>

  </div>
</AdminLayout>

