---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { getInternships } from '../../data/db.js';

export const prerender = false;

const internships = await getInternships();

// Unique categories for filtering
const categories = [...new Set(internships.map(i => i.category || 'General'))];
---

<AdminLayout title="Manage Internships - Margdarshak Admin" activeTab="internships">
  <div class="space-y-6">
    
    <!-- Page Header Bar -->
    <div class="glass-card-premium p-6 rounded-3xl border border-slate-200/60 shadow-sm flex flex-col sm:flex-row sm:items-center justify-between gap-4 relative overflow-hidden">
      <div class="absolute right-0 top-0 w-48 h-48 bg-gradient-to-br from-[#FF7043]/5 to-[#FFB300]/5 rounded-full blur-2xl pointer-events-none -z-10"></div>
      
      <div class="space-y-1 relative z-10">
        <h3 class="text-xl font-headline font-extrabold text-[#071426]">Internship Management</h3>
        <p class="text-xs text-slate-400 font-semibold">Create, update, or deprecate professional internship tracks.</p>
      </div>
      <button 
        id="open-add-modal-btn"
        class="px-4 py-2.5 btn-brand-gradient text-white rounded-xl font-headline font-bold text-xs transition-all flex items-center justify-center gap-1.5 shadow-md shadow-[#E53935]/15 hover:scale-[1.02] select-none"
      >
        <span class="material-symbols-outlined text-sm font-bold">add</span>
        Add Internship
      </button>
    </div>

    <!-- Filters, Search and Sorting -->
    <div class="glass-card-premium p-5 rounded-3xl border border-slate-200/60 shadow-sm flex flex-col lg:flex-row gap-4 items-center justify-between">
      
      <!-- Search Input -->
      <div class="relative w-full lg:max-w-md">
        <span class="material-symbols-outlined text-slate-400 text-base absolute left-3.5 top-3">search</span>
        <input 
          type="text" 
          id="internship-search"
          class="w-full pl-10 pr-4 py-2.5 text-xs rounded-xl border border-slate-200 bg-slate-50/50 placeholder-slate-400 focus:outline-none focus:border-[#E53935] focus:bg-white transition-all font-medium"
          placeholder="Search by name, category or description..."
        />
      </div>

      <!-- Filters & Sort -->
      <div class="grid grid-cols-1 sm:grid-cols-3 lg:flex lg:items-center gap-3 w-full lg:w-auto">
        
        <!-- Category Filter -->
        <select 
          id="filter-category"
          class="px-3 py-2.5 text-xs rounded-xl border border-slate-200 bg-white font-semibold text-slate-600 focus:outline-none focus:border-[#E53935] w-full lg:w-auto"
        >
          <option value="">All Categories</option>
          {categories.map(cat => (
            <option value={cat}>{cat}</option>
          ))}
        </select>

        <!-- Status Filter -->
        <select 
          id="filter-status"
          class="px-3 py-2.5 text-xs rounded-xl border border-slate-200 bg-white font-semibold text-slate-600 focus:outline-none focus:border-[#E53935] w-full lg:w-auto"
        >
          <option value="">All Statuses</option>
          <option value="Active">Active</option>
          <option value="Inactive">Inactive</option>
        </select>

        <!-- Sort dropdown -->
        <select 
          id="sort-internships"
          class="px-3 py-2.5 text-xs rounded-xl border border-slate-200 bg-white font-semibold text-slate-600 focus:outline-none focus:border-[#E53935] w-full lg:w-auto"
        >
          <option value="name-asc">Sort: Name (A-Z)</option>
          <option value="name-desc">Sort: Name (Z-A)</option>
          <option value="fee-asc">Sort: Fee (Low to High)</option>
          <option value="fee-desc">Sort: Fee (High to Low)</option>
        </select>

      </div>
    </div>

    <!-- Internships Container -->
    <div class="glass-card-premium rounded-3xl border border-slate-200/60 shadow-sm overflow-hidden" id="internships-container">
      <!-- Desktop Table Skeletons (Hidden on Mobile) -->
      <div class="overflow-x-auto hidden md:block">
        <table class="w-full text-left border-collapse">
          <thead>
            <tr class="bg-slate-50/50 border-b border-slate-100 text-[10px] font-headline font-extrabold text-slate-400 uppercase tracking-wider">
              <th class="px-6 py-4">Image</th>
              <th class="px-6 py-4">Internship Details</th>
              <th class="px-6 py-4">Category & Mode</th>
              <th class="px-6 py-4">Duration & Fee</th>
              <th class="px-6 py-4">Status</th>
              <th class="px-6 py-4 text-right">Actions</th>
            </tr>
          </thead>
          <tbody>
            {[1, 2, 3, 4, 5].map(() => (
              <tr class="animate-pulse border-b border-slate-100/70">
                <td class="px-6 py-4 shrink-0">
                  <div class="h-10 w-16 bg-slate-200 rounded-xl"></div>
                </td>
                <td class="px-6 py-4">
                  <div class="h-3 bg-slate-200 rounded w-44"></div>
                  <div class="h-2 bg-slate-100 rounded w-24 mt-1.5"></div>
                </td>
                <td class="px-6 py-4 space-y-1.5">
                  <div class="h-3 bg-slate-200 rounded w-24"></div>
                  <div class="h-2.5 bg-slate-100 rounded w-14"></div>
                </td>
                <td class="px-6 py-4 space-y-1.5">
                  <div class="h-3 bg-slate-200 rounded w-16"></div>
                  <div class="h-2.5 bg-slate-100 rounded w-12"></div>
                </td>
                <td class="px-6 py-4">
                  <div class="h-5 bg-slate-100 rounded-full w-16"></div>
                </td>
                <td class="px-6 py-4 text-right">
                  <div class="flex justify-end gap-1.5">
                    <div class="w-8 h-8 rounded-xl bg-slate-100"></div>
                    <div class="w-8 h-8 rounded-xl bg-slate-200"></div>
                  </div>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <!-- Mobile List Skeletons (Hidden on Desktop) -->
      <div class="block md:hidden divide-y divide-slate-100/70">
        {[1, 2, 3].map(() => (
          <div class="p-5 space-y-4 animate-pulse">
            <div class="flex items-start gap-4">
              <div class="w-20 h-14 bg-slate-200 rounded-xl shrink-0"></div>
              <div class="space-y-1.5 flex-1 min-w-0">
                <div class="h-3 bg-slate-200 rounded w-32"></div>
                <div class="h-2 bg-slate-100 rounded w-16"></div>
              </div>
            </div>
            <div class="grid grid-cols-2 gap-4">
              <div class="space-y-2">
                <div class="h-2.5 bg-slate-100 rounded w-20"></div>
                <div class="h-3 bg-slate-200 rounded w-16"></div>
              </div>
              <div class="space-y-2">
                <div class="h-2.5 bg-slate-100 rounded w-20"></div>
                <div class="h-3 bg-slate-200 rounded w-14"></div>
              </div>
            </div>
            <div class="pt-3 border-t border-slate-100 flex items-center justify-between">
              <div class="h-5 bg-slate-100 rounded-full w-16"></div>
              <div class="flex gap-2">
                <div class="w-8 h-8 rounded-xl bg-slate-100"></div>
                <div class="w-8 h-8 rounded-xl bg-slate-200"></div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

  </div>

  <!-- Internship Form Modal (Handles Add and Edit) -->
  <div id="internship-modal" class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-[#071426]/60 backdrop-blur-sm hidden" role="dialog" aria-modal="true">
    <div class="bg-white rounded-3xl border border-slate-200/60 shadow-2xl max-w-2xl w-full max-h-[90vh] flex flex-col overflow-hidden">
      
      <!-- Modal Header -->
      <div class="px-6 py-4 border-b border-slate-100 flex items-center justify-between shrink-0 bg-slate-50/80">
        <h4 id="modal-title" class="font-headline font-bold text-base text-[#071426]">Add Internship</h4>
        <button id="close-modal-btn" class="p-2 text-slate-400 hover:text-[#E53935] rounded-xl hover:bg-slate-100 transition-colors">
          <span class="material-symbols-outlined text-lg">close</span>
        </button>
      </div>

      <!-- Modal Body (Scrollable Form) -->
      <form id="internship-form" class="flex-grow overflow-y-auto p-6 space-y-4">
        <input type="hidden" id="edit-id" name="edit-id" />

        <!-- Internship Name -->
        <div class="space-y-1">
          <label for="internship-name" class="text-[10px] font-headline font-extrabold text-slate-500 uppercase tracking-wider block">Internship Name *</label>
          <input type="text" id="internship-name" name="name" required class="w-full px-3.5 py-2.5 text-xs rounded-xl border border-slate-200 focus:outline-none focus:border-[#E53935] bg-white transition-all font-medium" placeholder="e.g. AI Tools Internship" />
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <!-- Category -->
          <div class="space-y-1">
            <label for="internship-category" class="text-[10px] font-headline font-extrabold text-slate-500 uppercase tracking-wider block">Category *</label>
            <input type="text" id="internship-category" name="category" required class="w-full px-3.5 py-2.5 text-xs rounded-xl border border-slate-200 focus:outline-none focus:border-[#E53935] bg-white transition-all font-medium" placeholder="e.g. Accounting, SEO" />
          </div>
          <!-- Mode -->
          <div class="space-y-1">
            <label for="internship-mode" class="text-[10px] font-headline font-extrabold text-slate-500 uppercase tracking-wider block">Learning Mode *</label>
            <select id="internship-mode" name="mode" class="w-full px-3.5 py-2.5 text-xs rounded-xl border border-slate-200 bg-white font-semibold text-slate-600 focus:outline-none focus:border-[#E53935]">
              <option value="Hybrid">Hybrid (Classroom & Online)</option>
              <option value="Offline">Offline Center Only</option>
              <option value="Online">Online Classes Only</option>
            </select>
          </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <!-- Duration -->
          <div class="space-y-1">
            <label for="internship-duration" class="text-[10px] font-headline font-extrabold text-slate-500 uppercase tracking-wider block">Duration *</label>
            <input type="text" id="internship-duration" name="duration" required class="w-full px-3.5 py-2.5 text-xs rounded-xl border border-slate-200 focus:outline-none focus:border-[#E53935] bg-white transition-all font-medium" placeholder="e.g. 1 Month" />
          </div>
          <!-- Fee -->
          <div class="space-y-1">
            <label for="internship-fee" class="text-[10px] font-headline font-extrabold text-slate-500 uppercase tracking-wider block">Registration Fee *</label>
            <input type="text" id="internship-fee" name="fee" required class="w-full px-3.5 py-2.5 text-xs rounded-xl border border-slate-200 focus:outline-none focus:border-[#E53935] bg-white transition-all font-medium" placeholder="e.g. ₹1,000" />
          </div>
        </div>

        <!-- Hidden inputs for resolved Cloudinary values -->
        <input type="hidden" id="internship-image-url" name="image" />
        <input type="hidden" id="internship-image-public-id" />

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <!-- Internship Image Upload -->
          <div class="space-y-1.5 sm:col-span-2">
            <label class="text-[10px] font-headline font-extrabold text-slate-500 uppercase tracking-wider block">Internship Image *</label>

            <!-- Dropzone -->
            <div
              id="internship-image-dropzone"
              class="relative flex flex-col items-center justify-center gap-2 w-full rounded-2xl border-2 border-dashed border-slate-200 bg-slate-50/60 px-6 py-7 cursor-pointer transition-all duration-200 hover:border-[#E53935] hover:bg-rose-50/20 group"
            >
              <input type="file" id="internship-image-file-input" accept=".jpg,.jpeg,.png,.webp,image/jpeg,image/png,image/webp" class="absolute inset-0 w-full h-full opacity-0 cursor-pointer" />
              <div id="internship-image-dropzone-content" class="flex flex-col items-center gap-2 pointer-events-none text-center">
                <div class="w-10 h-10 rounded-xl bg-slate-100 group-hover:bg-rose-100 flex items-center justify-center transition-colors">
                  <span class="material-symbols-outlined text-xl text-slate-400 group-hover:text-[#E53935] transition-colors">cloud_upload</span>
                </div>
                <div>
                  <p class="text-xs font-headline font-bold text-slate-600">Click to upload or drag &amp; drop</p>
                  <p class="text-[10px] text-slate-400 font-medium mt-0.5">JPG, JPEG, PNG or WEBP &nbsp;&bull;&nbsp; Max 5 MB</p>
                </div>
              </div>
              <!-- Preview (hidden by default) -->
              <div id="internship-image-preview-wrap" class="hidden w-full flex-col items-center gap-3 pointer-events-none">
                <img id="internship-image-preview" src="" alt="Preview" class="w-full max-h-40 object-contain rounded-xl border border-slate-200 bg-white shadow-sm" />
                <div class="flex items-center gap-2 w-full">
                  <span class="material-symbols-outlined text-sm text-emerald-500">check_circle</span>
                  <span id="internship-image-filename" class="text-[10px] font-semibold text-slate-600 truncate flex-1"></span>
                  <button type="button" id="internship-image-remove-btn" class="shrink-0 text-[10px] font-headline font-bold text-[#E53935] hover:underline pointer-events-auto">Remove</button>
                </div>
              </div>
            </div>

            <!-- Error message -->
            <p id="internship-image-error" class="hidden text-[10px] font-semibold text-[#E53935] flex items-center gap-1">
              <span class="material-symbols-outlined text-sm">error</span>
              <span id="internship-image-error-text"></span>
            </p>
          </div>
        </div>

        <!-- Status (now full-width row after image) -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div class="space-y-1">
            <label for="internship-status" class="text-[10px] font-headline font-extrabold text-slate-500 uppercase tracking-wider block">Status *</label>
            <select id="internship-status" name="status" class="w-full px-3.5 py-2.5 text-xs rounded-xl border border-slate-200 bg-white font-semibold text-slate-600 focus:outline-none focus:border-[#E53935]">
              <option value="Active">Active</option>
              <option value="Inactive">Inactive</option>
            </select>
          </div>
        </div>

        <!-- Short Description -->
        <div class="space-y-1">
          <label for="internship-short-desc" class="text-[10px] font-headline font-extrabold text-slate-500 uppercase tracking-wider block">Short Description (Cards) *</label>
          <textarea id="internship-short-desc" name="shortDescription" required rows="2" class="w-full px-3.5 py-2.5 text-xs rounded-xl border border-slate-200 focus:outline-none focus:border-[#E53935] bg-white transition-all font-medium" placeholder="Brief 1-2 sentence description shown in grids..."></textarea>
        </div>

        <!-- Full Description -->
        <div class="space-y-1">
          <label for="internship-full-desc" class="text-[10px] font-headline font-extrabold text-slate-500 uppercase tracking-wider block">Full Overview Description *</label>
          <textarea id="internship-full-desc" name="fullDescription" required rows="3" class="w-full px-3.5 py-2.5 text-xs rounded-xl border border-slate-200 focus:outline-none focus:border-[#E53935] bg-white transition-all font-medium" placeholder="Comprehensive detail paragraph shown in overview page..."></textarea>
        </div>

        <!-- Additional details -->
        <div class="border-t border-slate-100 pt-4 space-y-4">
          <h5 class="text-[10px] font-headline font-extrabold text-[#071426] uppercase tracking-widest">Additional Detail Fields</h5>
          
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <!-- Eligible -->
            <div class="space-y-1">
              <label for="internship-eligible" class="text-[10px] font-headline font-extrabold text-slate-500 uppercase tracking-wider block">Eligibility Requirements</label>
              <input type="text" id="internship-eligible" name="eligible" class="w-full px-3.5 py-2.5 text-xs rounded-xl border border-slate-200 focus:outline-none focus:border-[#E53935] bg-white transition-all font-medium" placeholder="e.g. Commerce students, graduates" />
            </div>
            <!-- Tags -->
            <div class="space-y-1">
              <label for="internship-tags" class="text-[10px] font-headline font-extrabold text-slate-500 uppercase tracking-wider block">Tags (comma separated)</label>
              <input type="text" id="internship-tags" name="tags" class="w-full px-3.5 py-2.5 text-xs rounded-xl border border-slate-200 focus:outline-none focus:border-[#E53935] bg-white transition-all font-medium" placeholder="e.g. GST, Tax, Taxation" />
            </div>
          </div>

          <!-- Refund details -->
          <div class="space-y-1">
            <label for="internship-refund" class="text-[10px] font-headline font-extrabold text-slate-500 uppercase tracking-wider block">100% Refund Guidelines</label>
            <input type="text" id="internship-refund" name="refundDetails" class="w-full px-3.5 py-2.5 text-xs rounded-xl border border-slate-200 focus:outline-none focus:border-[#E53935] bg-white transition-all font-medium" placeholder="Specific conditions to receive refund" />
          </div>

          <!-- Certificate details -->
          <div class="space-y-1">
            <label for="internship-certificate" class="text-[10px] font-headline font-extrabold text-slate-500 uppercase tracking-wider block">Certification Details</label>
            <input type="text" id="internship-certificate" name="certificateDetails" class="w-full px-3.5 py-2.5 text-xs rounded-xl border border-slate-200 focus:outline-none focus:border-[#E53935] bg-white transition-all font-medium" placeholder="e.g. Experience Certificate details" />
          </div>

          <!-- Skills Covered / learnItems (one per line) -->
          <div class="space-y-1">
            <label for="internship-learn-items" class="text-[10px] font-headline font-extrabold text-slate-500 uppercase tracking-wider block">Skills Covered (one per line) *</label>
            <textarea id="internship-learn-items" name="learnItems" required rows="3" class="w-full px-3.5 py-2.5 text-xs rounded-xl border border-slate-200 focus:outline-none focus:border-[#E53935] bg-white transition-all font-medium text-xs font-mono" placeholder="Double-entry bookkeeping&#10;Inventory Management"></textarea>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <!-- Practical Tasks (one per line) -->
            <div class="space-y-1">
              <label for="internship-tasks" class="text-[10px] font-headline font-extrabold text-slate-500 uppercase tracking-wider block">Practical Tasks & Projects (one per line)</label>
              <textarea id="internship-tasks" name="practicalTasks" rows="3" class="w-full px-3 py-2 text-[10px] font-mono rounded-xl border border-slate-200 focus:outline-none focus:border-[#E53935] bg-white" placeholder="Drafting official corporate letters&#10;Creating automated expense trackers"></textarea>
            </div>
            <!-- Career Benefits (one per line) -->
            <div class="space-y-1">
              <label for="internship-benefits" class="text-[10px] font-headline font-extrabold text-slate-500 uppercase tracking-wider block">Career Benefits (one per line)</label>
              <textarea id="internship-benefits" name="careerBenefits" rows="3" class="w-full px-3 py-2 text-[10px] font-mono rounded-xl border border-slate-200 focus:outline-none focus:border-[#E53935] bg-white" placeholder="Standard office validation&#10;Certificate eligibility"></textarea>
            </div>
          </div>
        </div>

      </form>

      <!-- Modal Footer -->
      <div class="px-6 py-4 border-t border-slate-100 flex items-center justify-end gap-2.5 shrink-0 bg-slate-50/80">
        <button id="cancel-modal-btn" class="px-4 py-2 border border-slate-200 rounded-xl text-slate-600 font-headline font-bold text-xs hover:bg-slate-100 transition-colors">
          Cancel
        </button>
        <button id="save-internship-btn" type="submit" form="internship-form" class="px-4 py-2 btn-brand-gradient text-white rounded-xl font-headline font-bold text-xs shadow-sm flex items-center gap-1">
          <span class="material-symbols-outlined text-sm">save</span>
          Save Internship
        </button>
      </div>

    </div>
  </div>

  <div id="delete-modal" class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-[#071426]/60 backdrop-blur-sm hidden" role="dialog" aria-modal="true">
    <div class="bg-white rounded-3xl border border-slate-200 shadow-2xl max-w-sm w-full p-6 text-center space-y-6">
      <div class="w-14 h-14 rounded-full bg-rose-50 border border-rose-100 flex items-center justify-center text-[#E53935] mx-auto">
        <span class="material-symbols-outlined text-2xl font-bold">warning</span>
      </div>
      
      <div class="space-y-2">
        <h4 class="font-headline font-bold text-base text-[#071426]">Delete Internship?</h4>
        <p class="text-xs text-slate-500 font-semibold leading-relaxed">
          Are you sure you want to delete <strong id="delete-item-name" class="text-slate-800"></strong>? This will permanently remove it from the website.
        </p>
      </div>

      <div class="grid grid-cols-2 gap-2.5">
        <button id="cancel-delete-btn" class="py-2.5 border border-slate-200 rounded-xl text-slate-600 font-headline font-bold text-xs hover:bg-slate-100 transition-colors">
          No, Cancel
        </button>
        <button id="confirm-delete-btn" class="py-2.5 bg-[#E53935] text-white rounded-xl font-headline font-bold text-xs hover:bg-[#c12f31] transition-colors shadow-sm">
          Yes, Delete
        </button>
      </div>
    </div>
  </div>

  <script is:inline define:vars={{ internships }}>
    // Safe parse lists
    let internshipsList = internships || [];

    // Container elements
    const internshipsContainer = document.getElementById('internships-container');
    const searchInput = document.getElementById('internship-search');
    const categoryFilter = document.getElementById('filter-category');
    const statusFilter = document.getElementById('filter-status');
    const internshipsSort = document.getElementById('sort-internships');

    // Modal selectors
    const internshipModal = document.getElementById('internship-modal');
    const deleteModal = document.getElementById('delete-modal');
    const internshipForm = document.getElementById('internship-form');
    const modalTitle = document.getElementById('modal-title');
    const saveInternshipBtn = document.getElementById('save-internship-btn');
    
    // Open/Close buttons
    const openAddModalBtn = document.getElementById('open-add-modal-btn');
    const closeModalBtn = document.getElementById('close-modal-btn');
    const cancelModalBtn = document.getElementById('cancel-modal-btn');
    const cancelDeleteBtn = document.getElementById('cancel-delete-btn');
    const confirmDeleteBtn = document.getElementById('confirm-delete-btn');
    const deleteItemNameEl = document.getElementById('delete-item-name');

    let deleteTargetId = null;

    // Modal Helpers for smooth animations
    function showModal(modal) {
      modal.classList.remove('hidden');
      modal.classList.remove('modal-close-animate');
      modal.classList.add('modal-open-animate');
    }

    function hideModal(modal, onComplete = null) {
      modal.classList.remove('modal-open-animate');
      modal.classList.add('modal-close-animate');
      setTimeout(() => {
        modal.classList.add('hidden');
        modal.classList.remove('modal-close-animate');
        if (onComplete) onComplete();
      }, 200);
    }

    // Reset Form Fields
    function resetForm() {
      internshipForm.reset();
      document.getElementById('edit-id').value = '';
      document.getElementById('internship-image-url').value = '';
      document.getElementById('internship-image-public-id').value = '';
      resetImageWidget(
        'internship-image-dropzone',
        'internship-image-file-input',
        'internship-image-preview-wrap',
        'internship-image-preview',
        'internship-image-filename',
        'internship-image-error'
      );
      modalTitle.textContent = 'Add Internship';
      saveInternshipBtn.innerHTML = '<span class="material-symbols-outlined text-sm">save</span> Save Internship';
    }

    // Modal Controls
    if (openAddModalBtn) {
      openAddModalBtn.addEventListener('click', () => {
        resetForm();
        showModal(internshipModal);
      });
    }

    function hideModalTrigger() {
      hideModal(internshipModal);
    }

    if (closeModalBtn) closeModalBtn.addEventListener('click', hideModalTrigger);
    if (cancelModalBtn) cancelModalBtn.addEventListener('click', hideModalTrigger);

    // Render Table & Cards Helper
    function renderInternshipsTable() {
      const search = searchInput.value.toLowerCase();
      const category = categoryFilter.value;
      const status = statusFilter.value;
      const sort = internshipsSort.value;

      // Filter
      let filtered = internshipsList.filter(intern => {
        const matchesSearch = 
          intern.name?.toLowerCase().includes(search) || 
          intern.category?.toLowerCase().includes(search) ||
          intern.shortDescription?.toLowerCase().includes(search);
        
        const matchesCategory = !category || intern.category === category;
        const matchesStatus = !status || (intern.status || 'Active') === status;

        return matchesSearch && matchesCategory && matchesStatus;
      });

      // Sort
      filtered.sort((a, b) => {
        if (sort === 'name-asc') return a.name.localeCompare(b.name);
        if (sort === 'name-desc') return b.name.localeCompare(a.name);
        
        // Fee parsing helper
        const getVal = (str) => {
          const matched = String(str).replace(/[^0-9]/g, '');
          return matched ? parseInt(matched) : 0;
        };

        if (sort === 'fee-asc') return getVal(a.fee) - getVal(b.fee);
        if (sort === 'fee-desc') return getVal(b.fee) - getVal(a.fee);
        return 0;
      });

      // Render
      if (filtered.length === 0) {
        internshipsContainer.innerHTML = `
          <div class="p-12 text-center text-slate-400 font-semibold">
            No matching internships found.
          </div>
        `;
        return;
      }

      // Build Desktop Table HTML
      let tableHtml = `
        <div class="overflow-x-auto hidden md:block">
          <table class="w-full text-left border-collapse">
            <thead>
              <tr class="bg-slate-50/50 border-b border-slate-100 text-[10px] font-headline font-extrabold text-slate-400 uppercase tracking-wider">
                <th class="px-6 py-4">Image</th>
                <th class="px-6 py-4">Internship Details</th>
                <th class="px-6 py-4">Category & Mode</th>
                <th class="px-6 py-4">Duration & Fee</th>
                <th class="px-6 py-4">Status</th>
                <th class="px-6 py-4 text-right">Actions</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100/70 text-xs font-medium">
      `;

      // Build Mobile Cards HTML
      let cardsHtml = `
        <div class="block md:hidden divide-y divide-slate-100/70">
      `;

      filtered.forEach(intern => {
        const isInactive = intern.status === 'Inactive';
        const imageSrc = intern.image || '/assets/course_digital_marketing.png';
        const statusBadgeClass = isInactive ? 'bg-slate-100 text-slate-500' : 'bg-emerald-50 text-success';

        // Append Desktop Row
        tableHtml += `
          <tr class="hover:bg-slate-50/40 transition-colors">
            <td class="px-6 py-4 shrink-0">
              <img 
                src="${imageSrc}" 
                alt="${intern.name}" 
                class="h-10 w-16 object-cover rounded-xl border border-slate-200 bg-slate-100"
              />
            </td>
            <td class="px-6 py-4">
              <div class="font-headline font-bold text-[#071426] text-sm">${intern.name}</div>
              <div class="text-[9px] font-mono text-slate-400 tracking-tight mt-0.5">${intern.id}</div>
            </td>
            <td class="px-6 py-4 space-y-1">
              <div class="text-slate-700 font-semibold">${intern.category || 'General'}</div>
              <span class="inline-block px-2 py-0.5 bg-slate-100 border border-slate-200/50 rounded text-[8px] font-headline font-extrabold text-slate-500 uppercase tracking-wide">
                ${intern.mode || 'Hybrid'}
              </span>
            </td>
            <td class="px-6 py-4 space-y-0.5">
              <div class="font-bold text-[#071426] text-sm">${intern.fee}</div>
              <div class="text-[10px] text-slate-400 font-bold">${intern.duration}</div>
            </td>
            <td class="px-6 py-4">
              <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-[9px] font-headline font-extrabold uppercase ${statusBadgeClass}">
                <span class="w-1.5 h-1.5 rounded-full bg-current animate-pulse"></span>
                ${intern.status || 'Active'}
              </span>
            </td>
            <td class="px-6 py-4 text-right">
              <div class="flex items-center justify-end gap-1">
                <button 
                  class="p-2 text-slate-400 hover:text-[#071426] hover:bg-slate-100 rounded-xl transition-colors edit-btn"
                  data-id="${intern.id}"
                  title="Edit Internship"
                >
                  <span class="material-symbols-outlined text-lg">edit</span>
                </button>
                <button 
                  class="p-2 text-slate-400 hover:text-[#E53935] hover:bg-slate-100 rounded-xl transition-colors delete-btn"
                  data-id="${intern.id}"
                  data-name="${intern.name}"
                  title="Delete Internship"
                >
                  <span class="material-symbols-outlined text-lg">delete</span>
                </button>
              </div>
            </td>
          </tr>
        `;

        // Append Mobile Card
        cardsHtml += `
          <div class="p-5 space-y-4">
            <div class="flex items-start gap-4">
              <img 
                src="${imageSrc}" 
                alt="${intern.name}" 
                class="w-20 h-14 object-cover rounded-xl border border-slate-200 bg-slate-100 shrink-0"
              />
              <div class="min-w-0 flex-1">
                <div class="font-headline font-bold text-[#071426] text-sm line-clamp-2">${intern.name}</div>
                <div class="text-[9px] font-mono text-slate-400 mt-0.5 truncate">${intern.id}</div>
              </div>
            </div>

            <div class="grid grid-cols-2 gap-4 text-xs font-semibold">
              <div class="space-y-1">
                <span class="text-slate-400 text-[10px] uppercase font-bold tracking-wider block">Category & Mode</span>
                <div class="text-slate-700 font-semibold truncate">${intern.category || 'General'}</div>
                <span class="inline-block px-1.5 py-0.5 bg-slate-100 border border-slate-200/50 rounded text-[8px] font-headline font-extrabold text-slate-500 uppercase tracking-wide">
                  ${intern.mode || 'Hybrid'}
                </span>
              </div>
              <div class="space-y-1">
                <span class="text-slate-400 text-[10px] uppercase font-bold tracking-wider block">Duration & Fee</span>
                <div class="font-bold text-[#071426] text-xs">${intern.fee}</div>
                <div class="text-slate-400 font-bold text-[10px]">${intern.duration}</div>
              </div>
            </div>

            <div class="pt-3 border-t border-slate-100 flex items-center justify-between">
              <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-[9px] font-headline font-extrabold uppercase ${statusBadgeClass}">
                <span class="w-1.5 h-1.5 rounded-full bg-current animate-pulse"></span>
                ${intern.status || 'Active'}
              </span>
              <div class="flex items-center gap-1">
                <button 
                  class="w-11 h-11 flex items-center justify-center text-slate-400 hover:text-[#071426] hover:bg-slate-100 rounded-xl transition-colors edit-btn"
                  data-id="${intern.id}"
                  title="Edit Internship"
                >
                  <span class="material-symbols-outlined text-lg">edit</span>
                </button>
                <button 
                  class="w-11 h-11 flex items-center justify-center text-slate-400 hover:text-[#E53935] hover:bg-slate-100 rounded-xl transition-colors delete-btn"
                  data-id="${intern.id}"
                  data-name="${intern.name}"
                  title="Delete Internship"
                >
                  <span class="material-symbols-outlined text-lg">delete</span>
                </button>
              </div>
            </div>
          </div>
        `;
      });

      tableHtml += `
            </tbody>
          </table>
        </div>
      `;
      cardsHtml += `
        </div>
      `;

      internshipsContainer.innerHTML = tableHtml + cardsHtml;
      bindTableActions();
    }

    function bindTableActions() {
      // Edit
      document.querySelectorAll('.edit-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          resetForm();
          const id = btn.dataset.id;
          const intern = internshipsList.find(i => i.id === id);
          if (!intern) return;

          document.getElementById('edit-id').value = intern.id;
          document.getElementById('internship-name').value = intern.name;
          document.getElementById('internship-category').value = intern.category || '';
          document.getElementById('internship-mode').value = intern.mode || 'Hybrid';
          document.getElementById('internship-duration').value = intern.duration || '';
          document.getElementById('internship-fee').value = intern.fee || '';
          document.getElementById('internship-status').value = intern.status || 'Active';
          document.getElementById('internship-short-desc').value = intern.shortDescription || '';
          document.getElementById('internship-full-desc').value = intern.fullDescription || '';
          
          document.getElementById('internship-eligible').value = intern.eligible || '';
          document.getElementById('internship-tags').value = Array.isArray(intern.tags) ? intern.tags.join(', ') : '';
          document.getElementById('internship-refund').value = intern.refundDetails || '';
          document.getElementById('internship-certificate').value = intern.certificateDetails || '';
          
          document.getElementById('internship-learn-items').value = Array.isArray(intern.learnItems) ? intern.learnItems.join('\n') : '';
          document.getElementById('internship-tasks').value = Array.isArray(intern.practicalTasks) ? intern.practicalTasks.join('\n') : '';
          document.getElementById('internship-benefits').value = Array.isArray(intern.careerBenefits) ? intern.careerBenefits.join('\n') : '';

          // Populate image widget with existing image
          document.getElementById('internship-image-url').value = intern.image || '';
          document.getElementById('internship-image-public-id').value = intern.imagePublicId || '';
          if (intern.image) {
            showExistingImage(
              'internship-image-dropzone',
              'internship-image-file-input',
              'internship-image-preview-wrap',
              'internship-image-preview',
              'internship-image-filename',
              'internship-image-error',
              intern.image
            );
          }
          
          modalTitle.textContent = 'Edit Internship';
          saveInternshipBtn.innerHTML = '<span class="material-symbols-outlined text-sm">save</span> Update Internship';
          showModal(internshipModal);
        });
      });

      // Delete
      document.querySelectorAll('.delete-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          deleteTargetId = btn.dataset.id;
          deleteItemNameEl.textContent = btn.dataset.name;
          showModal(deleteModal);
        });
      });
    }

    // ─── Shared Image Upload Widget Helpers ──────────────────────────────────

    function showImageError(errorEl, text) {
      errorEl.classList.remove('hidden');
      errorEl.querySelector('span:last-child').textContent = text;
    }
    function clearImageError(errorEl) {
      errorEl.classList.add('hidden');
    }

    function resetImageWidget(dropzoneId, fileInputId, previewWrapId, previewImgId, filenameId, errorId) {
      const dz = document.getElementById(dropzoneId);
      const fileInput = document.getElementById(fileInputId);
      const previewWrap = document.getElementById(previewWrapId);
      const dzContent = dz.querySelector('[id$="dropzone-content"]') || dz.querySelector('.pointer-events-none.text-center');
      const errorEl = document.getElementById(errorId);
      if (fileInput) fileInput.value = '';
      if (previewWrap) previewWrap.classList.add('hidden');
      if (dzContent) dzContent.classList.remove('hidden');
      if (dz) {
        dz.classList.remove('border-[#E53935]', 'bg-rose-50/40', 'border-emerald-400', 'bg-emerald-50/20');
        dz.classList.add('border-slate-200', 'bg-slate-50/60');
      }
      if (errorEl) clearImageError(errorEl);
      if (window._internshipSelectedFile !== undefined) window._internshipSelectedFile = null;
    }

    function showExistingImage(dropzoneId, fileInputId, previewWrapId, previewImgId, filenameId, errorId, imageUrl) {
      const dz = document.getElementById(dropzoneId);
      const previewWrap = document.getElementById(previewWrapId);
      const previewImg = document.getElementById(previewImgId);
      const filenameEl = document.getElementById(filenameId);
      const dzContent = dz.querySelector('[id$="dropzone-content"]') || dz.querySelector('.pointer-events-none.text-center');
      if (previewImg) previewImg.src = imageUrl;
      if (filenameEl) filenameEl.textContent = 'Current image (click dropzone to replace)';
      if (previewWrap) {
        previewWrap.classList.remove('hidden');
        previewWrap.classList.add('flex');
      }
      if (dzContent) dzContent.classList.add('hidden');
      if (dz) {
        dz.classList.remove('border-slate-200', 'border-[#E53935]');
        dz.classList.add('border-emerald-400', 'bg-emerald-50/20');
      }
    }

    function showSelectedFile(dropzoneId, previewWrapId, previewImgId, filenameId, errorId, file) {
      const ALLOWED = ['image/jpeg', 'image/jpg', 'image/png', 'image/webp'];
      const MAX_MB = 5;
      const dz = document.getElementById(dropzoneId);
      const previewWrap = document.getElementById(previewWrapId);
      const previewImg = document.getElementById(previewImgId);
      const filenameEl = document.getElementById(filenameId);
      const errorEl = document.getElementById(errorId);
      const dzContent = dz.querySelector('[id$="dropzone-content"]') || dz.querySelector('.pointer-events-none.text-center');

      clearImageError(errorEl);

      if (!ALLOWED.includes(file.type)) {
        showImageError(errorEl, 'Only JPG, JPEG, PNG or WEBP images are accepted.');
        return false;
      }
      if (file.size > MAX_MB * 1024 * 1024) {
        showImageError(errorEl, `File must be under ${MAX_MB} MB. This file is ${(file.size / 1024 / 1024).toFixed(1)} MB.`);
        return false;
      }

      const reader = new FileReader();
      reader.onload = (e) => {
        if (previewImg) previewImg.src = e.target.result;
        if (filenameEl) filenameEl.textContent = file.name;
        if (previewWrap) {
          previewWrap.classList.remove('hidden');
          previewWrap.classList.add('flex');
        }
        if (dzContent) dzContent.classList.add('hidden');
        if (dz) {
          dz.classList.remove('border-slate-200', 'border-[#E53935]');
          dz.classList.add('border-emerald-400', 'bg-emerald-50/20');
        }
      };
      reader.readAsDataURL(file);
      return true;
    }

    // ─── Wire up Internship Image Widget ───────────────────────────────────────

    window._internshipSelectedFile = null;

    const internshipDropzone = document.getElementById('internship-image-dropzone');
    const internshipFileInput = document.getElementById('internship-image-file-input');
    const internshipRemoveBtn = document.getElementById('internship-image-remove-btn');

    if (internshipFileInput) {
      internshipFileInput.addEventListener('change', (e) => {
        const file = e.target.files[0];
        if (!file) return;
        const valid = showSelectedFile(
          'internship-image-dropzone', 'internship-image-preview-wrap',
          'internship-image-preview', 'internship-image-filename', 'internship-image-error', file
        );
        if (valid) window._internshipSelectedFile = file;
        else { internshipFileInput.value = ''; window._internshipSelectedFile = null; }
      });
    }

    if (internshipDropzone) {
      internshipDropzone.addEventListener('dragover', (e) => {
        e.preventDefault();
        internshipDropzone.classList.add('border-[#E53935]', 'bg-rose-50/20');
        internshipDropzone.classList.remove('border-slate-200');
      });
      internshipDropzone.addEventListener('dragleave', () => {
        internshipDropzone.classList.remove('border-[#E53935]', 'bg-rose-50/20');
        internshipDropzone.classList.add('border-slate-200');
      });
      internshipDropzone.addEventListener('drop', (e) => {
        e.preventDefault();
        internshipDropzone.classList.remove('border-[#E53935]', 'bg-rose-50/20');
        internshipDropzone.classList.add('border-slate-200');
        const file = e.dataTransfer.files[0];
        if (!file) return;
        const valid = showSelectedFile(
          'internship-image-dropzone', 'internship-image-preview-wrap',
          'internship-image-preview', 'internship-image-filename', 'internship-image-error', file
        );
        if (valid) window._internshipSelectedFile = file;
        else window._internshipSelectedFile = null;
      });
    }

    if (internshipRemoveBtn) {
      internshipRemoveBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        window._internshipSelectedFile = null;
        document.getElementById('internship-image-url').value = '';
        document.getElementById('internship-image-public-id').value = '';
        resetImageWidget(
          'internship-image-dropzone', 'internship-image-file-input',
          'internship-image-preview-wrap', 'internship-image-preview',
          'internship-image-filename', 'internship-image-error'
        );
      });
    }

    // ─── Submit Handler ───────────────────────────────────────────────────────

    // Submit handler
    if (internshipForm) {
      internshipForm.addEventListener('submit', async (e) => {
        e.preventDefault();

        // Validate that we have an image
        const existingUrl = document.getElementById('internship-image-url').value;
        const hasNewFile = !!window._internshipSelectedFile;
        if (!hasNewFile && !existingUrl) {
          showImageError(document.getElementById('internship-image-error'), 'Please upload an internship image.');
          return;
        }
        
        const originalBtnContent = saveInternshipBtn.innerHTML;
        saveInternshipBtn.disabled = true;
        saveInternshipBtn.innerHTML = '<span class="material-symbols-outlined text-sm animate-spin">refresh</span> Uploading...';

        const editId = document.getElementById('edit-id').value;
        let imageUrl = existingUrl;
        let imagePublicId = document.getElementById('internship-image-public-id').value;

        // Upload new file to Cloudinary if one was selected
        if (hasNewFile) {
          try {
            const oldPublicId = imagePublicId;

            const formData = new FormData();
            formData.append('image', window._internshipSelectedFile);
            const uploadRes = await fetch('/api/upload-image?folder=internships', {
              method: 'POST',
              body: formData
            });
            const uploadData = await uploadRes.json();

            if (!uploadRes.ok || !uploadData.success) {
              throw new Error(uploadData.error || 'Image upload failed.');
            }

            imageUrl = uploadData.url;
            imagePublicId = uploadData.publicId;

            // Delete old Cloudinary image if replacing
            if (oldPublicId && oldPublicId !== imagePublicId) {
              fetch(`/api/upload-image?publicId=${encodeURIComponent(oldPublicId)}`, { method: 'DELETE' })
                .catch(() => {}); // non-fatal
            }
          } catch (uploadErr) {
            window.showToast(uploadErr.message || 'Failed to upload image.', 'error');
            saveInternshipBtn.disabled = false;
            saveInternshipBtn.innerHTML = originalBtnContent;
            return;
          }
        }

        saveInternshipBtn.innerHTML = '<span class="material-symbols-outlined text-sm">refresh</span> Saving...';

        const apiUrl = editId ? `/api/internships?id=${editId}` : '/api/internships';
        const method = editId ? 'PUT' : 'POST';

        const payload = {
          name: document.getElementById('internship-name').value,
          category: document.getElementById('internship-category').value,
          mode: document.getElementById('internship-mode').value,
          duration: document.getElementById('internship-duration').value,
          fee: document.getElementById('internship-fee').value,
          image: imageUrl,
          imagePublicId: imagePublicId,
          status: document.getElementById('internship-status').value,
          shortDescription: document.getElementById('internship-short-desc').value,
          fullDescription: document.getElementById('internship-full-desc').value,
          eligible: document.getElementById('internship-eligible').value,
          tags: document.getElementById('internship-tags').value,
          refundDetails: document.getElementById('internship-refund').value,
          certificateDetails: document.getElementById('internship-certificate').value,
          learnItems: document.getElementById('internship-learn-items').value,
          practicalTasks: document.getElementById('internship-tasks').value,
          careerBenefits: document.getElementById('internship-benefits').value
        };

        try {
          const res = await fetch(apiUrl, {
            method,
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
          });

          const data = await res.json();
          
          if (res.ok && data.success) {
            hideModal(internshipModal);
            window.showToast(`Internship successfully ${editId ? 'updated' : 'added'}!`);
            setTimeout(() => window.location.reload(), 1000);
          } else {
            window.showToast(data.error || 'Failed to save internship.', 'error');
            saveInternshipBtn.disabled = false;
            saveInternshipBtn.innerHTML = originalBtnContent;
          }
        } catch (err) {
          console.error(err);
          window.showToast('Network error, failed to save.', 'error');
          saveInternshipBtn.disabled = false;
          saveInternshipBtn.innerHTML = originalBtnContent;
        }
      });
    }

    // Cancel Delete
    if (cancelDeleteBtn) {
      cancelDeleteBtn.addEventListener('click', () => {
        hideModal(deleteModal, () => {
          deleteTargetId = null;
        });
      });
    }

    // Confirm Delete
    if (confirmDeleteBtn) {
      confirmDeleteBtn.addEventListener('click', async () => {
        if (!deleteTargetId) return;

        confirmDeleteBtn.disabled = true;
        confirmDeleteBtn.textContent = 'Deleting...';

        try {
          const res = await fetch(`/api/internships?id=${deleteTargetId}`, {
            method: 'DELETE'
          });

          const data = await res.json();

          if (res.ok && data.success) {
            hideModal(deleteModal);
            window.showToast('Internship successfully deleted!');
            setTimeout(() => window.location.reload(), 1000);
          } else {
            window.showToast(data.error || 'Failed to delete internship.', 'error');
            confirmDeleteBtn.disabled = false;
            confirmDeleteBtn.textContent = 'Yes, Delete';
          }
        } catch (err) {
          console.error(err);
          window.showToast('Network error, failed to delete.', 'error');
          confirmDeleteBtn.disabled = false;
          confirmDeleteBtn.textContent = 'Yes, Delete';
        }
      });
    }

    // Attach filters listeners
    if (searchInput) searchInput.addEventListener('input', renderInternshipsTable);
    if (categoryFilter) categoryFilter.addEventListener('change', renderInternshipsTable);
    if (statusFilter) statusFilter.addEventListener('change', renderInternshipsTable);
    if (internshipsSort) internshipsSort.addEventListener('change', renderInternshipsTable);

    // Initial table draw
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', renderInternshipsTable);
    } else {
      renderInternshipsTable();
    }
  </script>
</AdminLayout>

