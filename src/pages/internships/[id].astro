---
import Layout from '../../layouts/Layout.astro';
import { getInternships } from '../../data/db.js';

export async function getStaticPaths() {
  const internships = getInternships();
  return internships.map((internship) => ({
    params: { id: internship.id },
    props: { internship },
  }));
}

const { internship } = Astro.props;
const isNotFound = !internship || internship.status === 'Inactive';

// Fetch related internships
const allInternships = getInternships();
const relatedInternships = allInternships
  .filter(i => i.id !== internship?.id && i.status !== 'Inactive')
  .slice(0, 3);

const whatsappLink = !isNotFound
  ? `https://wa.me/919229025257?text=Hi,%20I%20have%20questions%20regarding%20the%20${encodeURIComponent(internship.name)}%20program.`
  : '';

// Helper to get skill icons
function getSkillIcon(index) {
  const icons = [
    'terminal', 'architecture', 'integration_instructions', 'api', 
    'developer_board', 'query_stats', 'verified_user', 'layers', 
    'chart_data', 'payments', 'account_balance', 'contract'
  ];
  return icons[index % icons.length];
}

// 6-Step Journey Data
const journeySteps = [
  { step: "01", title: "Enroll & Set Up", desc: "Submit your details and complete the ₹1,000 security registration." },
  { step: "02", title: "Skill Onboarding", desc: "Get access to guides, portal logins, and initial simulated projects." },
  { step: "03", title: "Practical Work", desc: "Work on real invoices, spreadsheets, code files, or marketing calendars." },
  { step: "04", title: "Task Submission", desc: "Submit your weekly tasks and assignments for project team evaluation." },
  { step: "05", title: "Certification", desc: "Get your experience certificate stamped with verified performance grades." },
  { step: "06", title: "Refund & Support", desc: "Claim 100% registration refund & get active resume building support." }
];

// Play store link & phone details
const playStoreLink = "https://play.google.com/store/apps/details?id=co.varys.shacc";
const institutePhone = "+919229025257";
const dialPhone = "tel:+919229025257";
---

{isNotFound ? (
  <Layout title="Internship Not Found - Margdarshak Shikshan Sansthan">
    <section class="py-24 text-center bg-slate-50 relative overflow-hidden flex items-center justify-center min-h-[70vh]">
      <div class="absolute inset-0 bg-gradient-to-t from-slate-100 via-transparent to-transparent opacity-60"></div>
      <div class="max-w-md mx-auto space-y-6 px-6 relative z-10 glass-card-premium p-10 rounded-3xl border border-slate-200 shadow-xl">
        <span class="material-symbols-outlined text-6xl text-secondary animate-pulse font-bold">error</span>
        <h1 class="text-3xl font-headline font-black text-primary">Internship Not Found</h1>
        <p class="text-slate-600 text-sm">The internship program you are looking for does not exist or has been deactivated by our administrator.</p>
        <a href="/internships" class="inline-block w-full py-3 btn-brand-gradient text-white rounded-xl font-bold text-sm hover:scale-[1.02] transition-all shadow-md">
          Return to Internships
        </a>
      </div>
    </section>
  </Layout>
) : (
  <Layout 
    title={`${internship.name} — 1-Month Practical Internship | Margdarshak Darbhanga`} 
    description={internship.shortDescription}
    ogImage={internship.image}
    ogType="website"
    jsonLd={{
      "@context": "https://schema.org",
      "@type": "Course",
      "name": internship.name,
      "description": internship.shortDescription,
      "provider": {
        "@type": "Organization",
        "name": "Margdarshak Shikshan Sansthan",
        "sameAs": "https://margdarshak.in"
      },
      "offers": {
        "@type": "Offer",
        "price": "1000",
        "priceCurrency": "INR",
        "availability": "https://schema.org/InStock"
      },
      "hasCourseInstance": {
        "@type": "CourseInstance",
        "courseMode": "blended",
        "courseWorkload": internship.duration
      }
    }}
  >
    
    <!-- 1. Hero Section -->
    <section class="hero-gradient text-white py-10 md:py-20 relative overflow-hidden">
      <!-- Glow Blobs -->
      <div class="absolute top-1/4 left-1/10 w-96 h-96 bg-secondary/15 rounded-full filter blur-[120px] pointer-events-none animate-pulse-glow" aria-hidden="true"></div>
      <div class="absolute bottom-10 right-10 w-80 h-80 bg-accent/15 rounded-full filter blur-[100px] pointer-events-none animate-float-slow" aria-hidden="true"></div>

      <div class="max-w-[1440px] mx-auto px-4 md:px-6 relative z-10">
        
        <!-- Breadcrumbs -->
        <div class="flex flex-wrap items-center gap-2 text-xs md:text-sm text-slate-300 font-bold uppercase tracking-wider mb-6">
          <a href="/" class="hover:text-white transition-colors">Home</a>
          <span class="text-slate-500">/</span>
          <a href="/internships" class="hover:text-white transition-colors">Internships</a>
          <span class="text-slate-500">/</span>
          <span class="text-accent">{internship.name}</span>
        </div>

        <!-- Split Grid Layout -->
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
          
          <!-- Hero Details (Left Column) -->
          <div class="lg:col-span-7 space-y-6 text-left">
            <div class="inline-flex items-center gap-2 bg-white/5 border border-white/10 px-4 py-1.5 rounded-full backdrop-blur-md">
              <span class="w-2.5 h-2.5 rounded-full bg-secondary animate-ping"></span>
              <span class="text-xs font-bold uppercase tracking-wider text-accent font-headline">1-Month Smart Internship</span>
            </div>
            
            <h1 class="text-3xl md:text-5xl lg:text-6xl font-headline font-black leading-tight">
              {internship.name}
            </h1>
            
            <p class="text-slate-300 text-sm md:text-base leading-relaxed font-body max-w-2xl">
              {internship.shortDescription}
            </p>

            <!-- Hero CTA Trigger -->
            <div class="flex flex-wrap gap-4 pt-4">
              <a href={`/register?program=internship&internship=${internship.id}`} class="px-8 py-4 btn-brand-gradient text-white font-bold rounded-2xl text-sm transition-all shadow-lg hover:scale-105 flex items-center gap-2">
                Register Now <span class="material-symbols-outlined text-sm font-bold">arrow_forward</span>
              </a>
              <a href="#overview-section" class="px-8 py-4 bg-white/10 hover:bg-white/15 border border-white/10 text-white font-bold rounded-2xl text-sm transition-all shadow-md flex items-center justify-center">
                Explore Program Details
              </a>
            </div>
          </div>

          <!-- Hero Image visual card (Right Column) -->
          <div class="lg:col-span-5 relative">
            <div class="absolute -inset-1.5 rounded-3xl bg-gradient-to-r from-secondary to-accent opacity-25 blur-lg animate-float-medium"></div>
            <div class="relative rounded-3xl overflow-hidden border border-white/10 shadow-2xl bg-primary/45 backdrop-blur-xl">
              <img src={internship.image} alt={`${internship.name} internship at Margdarshak`} class="w-full h-64 md:h-80 object-cover" loading="eager" fetchpriority="high" decoding="async" width="600" height="320" />
              <div class="absolute inset-0 bg-gradient-to-t from-primary via-transparent to-transparent opacity-85"></div>
              
              <!-- Absolute Details Overlapping Image -->
              <div class="absolute bottom-6 left-6 right-6 flex justify-between items-end">
                <div class="space-y-1">
                  <span class="text-[10px] text-accent uppercase font-black tracking-wider block">Official Program Partner</span>
                  <h4 class="text-white font-headline font-bold text-sm">Margdarshak Shikshan Sansthan</h4>
                </div>
                <div class="bg-secondary text-white text-[10px] font-black px-3 py-1.5 rounded-lg border border-secondary/20 shadow-md">
                  ISO 9001:2015
                </div>
              </div>
            </div>
          </div>

        </div>

      </div>
    </section>

    <!-- 2. Quick Course Snapshots -->
    <section class="bg-slate-100 py-8 border-b border-slate-200/60">
      <div class="max-w-[1440px] mx-auto px-4 md:px-6">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          
          <div class="bg-white p-4 rounded-2xl border border-slate-200/80 shadow-sm flex items-center gap-3">
            <div class="w-10 h-10 rounded-xl bg-secondary/10 flex items-center justify-center text-secondary shrink-0">
              <span class="material-symbols-outlined text-xl">schedule</span>
            </div>
            <div>
              <span class="text-[10px] text-slate-400 font-bold uppercase block">Duration</span>
              <span class="text-xs font-extrabold text-primary">{internship.duration}</span>
            </div>
          </div>

          <div class="bg-white p-4 rounded-2xl border border-slate-200/80 shadow-sm flex items-center gap-3">
            <div class="w-10 h-10 rounded-xl bg-accent/10 flex items-center justify-center text-accent shrink-0">
              <span class="material-symbols-outlined text-xl font-bold">layers</span>
            </div>
            <div>
              <span class="text-[10px] text-slate-400 font-bold uppercase block">Learning Mode</span>
              <span class="text-xs font-extrabold text-primary">Hybrid Learning</span>
            </div>
          </div>

          <div class="bg-white p-4 rounded-2xl border border-slate-200/80 shadow-sm flex items-center gap-3">
            <div class="w-10 h-10 rounded-xl bg-emerald-100 flex items-center justify-center text-emerald-600 shrink-0">
              <span class="material-symbols-outlined text-xl">payments</span>
            </div>
            <div>
              <span class="text-[10px] text-slate-400 font-bold uppercase block">Refundable Fee</span>
              <span class="text-xs font-extrabold text-primary">{internship.fee}</span>
            </div>
          </div>

          <div class="bg-white p-4 rounded-2xl border border-slate-200/80 shadow-sm flex items-center gap-3">
            <div class="w-10 h-10 rounded-xl bg-blue-50 flex items-center justify-center text-blue-600 shrink-0">
              <span class="material-symbols-outlined text-xl">school</span>
            </div>
            <div>
              <span class="text-[10px] text-slate-400 font-bold uppercase block">Eligibility</span>
              <span class="text-xs font-extrabold text-primary">Students & Grads</span>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- Main Detail Content Grid -->
    <section class="py-16 bg-white" id="overview-section">
      <div class="max-w-[1440px] mx-auto px-4 md:px-6">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">
          
          <!-- Left Column Content Areas (Col-span 8) -->
          <div class="lg:col-span-8 space-y-16">
            
            <!-- 3. Overview -->
            <div class="space-y-4">
              <h2 class="text-2xl md:text-3xl font-headline font-black text-primary flex items-center gap-2">
                <span class="w-2.5 h-6 bg-secondary rounded-full"></span>
                Internship Overview
              </h2>
              <div class="glass-card-premium p-6 md:p-8 rounded-3xl border border-slate-200/60 bg-slate-50/50 shadow-sm">
                <p class="text-slate-600 leading-relaxed text-base md:text-lg font-body font-medium">
                  {internship.fullDescription}
                </p>
                <div class="mt-6 pt-6 border-t border-slate-200/60 text-sm text-slate-500 font-semibold flex flex-col sm:flex-row gap-2 sm:gap-6">
                  <div class="flex items-center gap-2">
                    <span class="material-symbols-outlined text-secondary text-lg">school</span>
                    <span><strong>Eligibility:</strong> {internship.eligible}</span>
                  </div>
                </div>
              </div>
            </div>

            <!-- 4. What You'll Learn / Skills Mastered -->
            <div class="space-y-6">
              <div>
                <h2 class="text-2xl md:text-3xl font-headline font-black text-primary flex items-center gap-2">
                  <span class="w-2.5 h-6 bg-secondary rounded-full"></span>
                  Skills You Will Master
                </h2>
                <p class="text-xs md:text-sm text-slate-500 font-medium mt-1">Acquire real competence in the following toolsets and applications:</p>
              </div>

              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                {(internship.learnItems || []).map((item, idx) => (
                  <div class="glass-card-premium p-5 rounded-2xl border border-slate-200/60 bg-white hover:border-secondary/20 hover-lift flex items-start gap-4 shadow-sm transition-all duration-300">
                    <div class="w-10 h-10 rounded-xl bg-secondary/5 border border-secondary/10 flex items-center justify-center text-secondary shrink-0 animate-pulse-glow">
                      <span class="material-symbols-outlined text-xl font-bold">{getSkillIcon(idx)}</span>
                    </div>
                    <div class="space-y-1">
                      <h4 class="text-slate-800 font-headline font-black text-sm md:text-base leading-snug">{item.split(' - ')[0] || item}</h4>
                      <p class="text-slate-500 text-xs font-semibold font-body">Practical application and simulation exercises.</p>
                    </div>
                  </div>
                ))}
              </div>
            </div>

            <!-- 5. Tools & Technologies (Dynamic badges based on tags) -->
            <div class="space-y-6">
              <h2 class="text-2xl md:text-3xl font-headline font-black text-primary flex items-center gap-2">
                <span class="w-2.5 h-6 bg-secondary rounded-full"></span>
                Tools & Platforms Covered
              </h2>
              <div class="flex flex-wrap gap-3">
                {(internship.tags || []).map(tag => (
                  <span class="px-5 py-2.5 bg-slate-50 border border-slate-200 text-slate-700 rounded-full font-bold text-xs md:text-sm shadow-sm transition-all hover:bg-secondary hover:text-white hover:border-secondary cursor-default">
                    {tag}
                  </span>
                ))}
                {(!internship.tags || internship.tags.length < 3) && (
                  <>
                    <span class="px-5 py-2.5 bg-slate-50 border border-slate-200 text-slate-700 rounded-full font-bold text-xs md:text-sm shadow-sm">AI Productivity</span>
                    <span class="px-5 py-2.5 bg-slate-50 border border-slate-200 text-slate-700 rounded-full font-bold text-xs md:text-sm shadow-sm">Slack & ClickUp</span>
                    <span class="px-5 py-2.5 bg-slate-50 border border-slate-200 text-slate-700 rounded-full font-bold text-xs md:text-sm shadow-sm">Google Workspace</span>
                  </>
                )}
              </div>
            </div>

            <!-- 6. Curriculum Timeline / 6-Step Journey -->
            <div class="space-y-8">
              <div>
                <h2 class="text-2xl md:text-3xl font-headline font-black text-primary flex items-center gap-2">
                  <span class="w-2.5 h-6 bg-secondary rounded-full"></span>
                  Learning Journey & Roadmap
                </h2>
                <p class="text-xs md:text-sm text-slate-500 font-medium mt-1">Our streamlined 6-step roadmap towards career validation:</p>
              </div>

              <!-- Timeline Container -->
              <div class="relative border-l-2 border-slate-200 pl-8 ml-4 space-y-10">
                {journeySteps.map((stepItem, idx) => (
                  <div class="relative group">
                    <!-- Bullet Icon Indicator -->
                    <div class="absolute -left-[41px] top-0.5 w-6 h-6 rounded-full bg-white border-2 border-slate-300 group-hover:border-secondary transition-colors duration-300 flex items-center justify-center">
                      <div class="w-2.5 h-2.5 rounded-full bg-slate-300 group-hover:bg-secondary transition-colors duration-300"></div>
                    </div>
                    
                    <div class="space-y-1.5">
                      <span class="text-xs font-bold text-secondary font-headline uppercase block">Step {stepItem.step}</span>
                      <h4 class="text-slate-800 font-headline font-black text-base md:text-lg leading-snug group-hover:text-primary transition-colors">{stepItem.title}</h4>
                      <p class="text-slate-500 text-xs md:text-sm leading-relaxed font-body max-w-xl">{stepItem.desc}</p>
                    </div>
                  </div>
                ))}
              </div>
            </div>

            <!-- 7. Real Project Experience / Practical Portfolio -->
            <div class="space-y-6">
              <div class="glass-card-premium p-6 md:p-8 rounded-3xl border border-secondary/15 bg-secondary/[0.01] space-y-6">
                <div class="flex items-center gap-3">
                  <div class="w-12 h-12 rounded-2xl bg-secondary/10 flex items-center justify-center text-secondary border border-secondary/20">
                    <span class="material-symbols-outlined text-2xl font-bold">assignment_turned_in</span>
                  </div>
                  <div>
                    <h3 class="text-xl md:text-2xl font-headline font-black text-primary">Practical Work Portfolio</h3>
                    <p class="text-xs text-slate-500 font-medium">Weekly deliverables required to complete the 1-month program:</p>
                  </div>
                </div>

                <div class="grid grid-cols-1 gap-4">
                  {(internship.practicalTasks || []).map((task, idx) => (
                    <div class="flex items-start gap-4 bg-white p-4 rounded-2xl border border-slate-200/60 shadow-sm hover:border-secondary/25 transition-all duration-300">
                      <div class="w-6 h-6 rounded-full bg-slate-100 border border-slate-200 flex items-center justify-center text-[10px] font-bold text-slate-400 mt-0.5">
                        {idx + 1}
                      </div>
                      <div class="space-y-1 flex-1">
                        <div class="flex items-center justify-between gap-4">
                          <h4 class="text-slate-800 font-headline font-bold text-xs md:text-sm">{task}</h4>
                          <span class="text-[9px] bg-slate-100 text-slate-500 font-extrabold px-2 py-0.5 rounded uppercase shrink-0">Assigned</span>
                        </div>
                        <p class="text-[11px] text-slate-500 font-body font-medium">Submission required in weekly assessment file.</p>
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            </div>

            <!-- 8. Certification Section -->
            <div class="space-y-6">
              <h2 class="text-2xl md:text-3xl font-headline font-black text-primary flex items-center gap-2">
                <span class="w-2.5 h-6 bg-secondary rounded-full"></span>
                Official Experience Certification
              </h2>

              <div class="grid grid-cols-1 md:grid-cols-12 gap-8 items-center bg-white p-6 md:p-8 rounded-3xl border border-slate-200/80 shadow-premium">
                <!-- Trust Text (Left Side) -->
                <div class="md:col-span-7 space-y-5">
                  <div class="inline-block bg-accent/20 text-primary border border-accent/30 text-[10px] font-extrabold px-3 py-1 rounded-full uppercase tracking-wider">
                    ISO 9001:2015 Verified
                  </div>
                  <h4 class="text-xl font-headline font-bold text-primary">
                    Stamped Experience Record & Performance Grade
                  </h4>
                  <p class="text-slate-600 text-sm leading-relaxed font-body font-medium">
                    {internship.certificateDetails} Upon successful evaluation of tasks, you will receive a verified Internship Experience Certificate. Your certificate will contain:
                  </p>
                  <ul class="space-y-2 text-xs text-slate-700 font-semibold font-headline">
                    <li class="flex items-center gap-2">
                      <span class="material-symbols-outlined text-secondary text-base">check_circle</span> Verified Corporate Performance Grades (A+, A, B)
                    </li>
                    <li class="flex items-center gap-2">
                      <span class="material-symbols-outlined text-secondary text-base">check_circle</span> QR Code verification link readable by employers
                    </li>
                    <li class="flex items-center gap-2">
                      <span class="material-symbols-outlined text-secondary text-base">check_circle</span> Stamped authorization from Registered NGO / Institution
                    </li>
                  </ul>
                </div>

                <!-- Styled HTML Mock Certificate Frame (Right Side) -->
                <div class="md:col-span-5 relative">
                  <div class="absolute -inset-1 rounded-2xl bg-gradient-to-r from-accent to-secondary opacity-15 blur-md"></div>
                  <div class="relative bg-slate-50 border-4 border-slate-200 p-4 rounded-2xl shadow-lg space-y-4 text-center select-none overflow-hidden min-h-[220px] flex flex-col justify-between">
                    <div class="absolute -right-6 -bottom-6 w-24 h-24 bg-accent/10 rounded-full"></div>
                    
                    <div class="space-y-1">
                      <div class="text-[9px] uppercase tracking-widest text-slate-400 font-bold">Certificate of Experience</div>
                      <div class="w-6 h-0.5 bg-accent mx-auto"></div>
                    </div>
                    
                    <div class="space-y-1 py-3">
                      <div class="text-[7px] text-slate-400 uppercase">This is presented to</div>
                      <div class="text-xs font-headline font-bold text-primary border-b border-dashed border-slate-300 w-3/4 mx-auto pb-0.5">Your Full Name</div>
                      <div class="text-[6px] text-slate-500 max-w-[90%] mx-auto mt-1 leading-normal font-medium font-body">For outstanding performance and successful task completions in {internship.name}.</div>
                    </div>

                    <div class="flex justify-between items-center pt-2 border-t border-slate-100 text-[6px] text-slate-400">
                      <div>
                        <div class="font-bold text-slate-700">Margdarshak</div>
                        <div>Authorized Signature</div>
                      </div>
                      <div class="w-8 h-8 rounded-full bg-accent/15 border border-accent/20 flex items-center justify-center font-black text-accent text-[8px]">
                        SEAL
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <!-- 9. Career Benefits (Bento Grid) -->
            <div class="space-y-6">
              <h2 class="text-2xl md:text-3xl font-headline font-black text-primary flex items-center gap-2">
                <span class="w-2.5 h-6 bg-secondary rounded-full"></span>
                Career Acceleration Benefits
              </h2>

              <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <!-- Bento Card 1: Resume Building -->
                <div class="md:col-span-2 glass-card-premium p-6 rounded-2xl border border-slate-200/80 bg-white hover:border-secondary/20 shadow-sm flex flex-col justify-between space-y-4">
                  <div class="space-y-2">
                    <span class="material-symbols-outlined text-secondary text-3xl font-bold">description</span>
                    <h4 class="text-lg font-headline font-bold text-primary">Resume Building & Highlights</h4>
                    <p class="text-slate-500 text-xs leading-relaxed font-body font-medium">
                      We assist you in formatting this internship role on your resume. Learn how to present completed practical tasks as real project details to highlight hands-on familiarity.
                    </p>
                  </div>
                  <div class="flex gap-2 text-[10px] text-slate-600 font-extrabold uppercase pt-2">
                    <span class="bg-slate-100 px-2.5 py-1 rounded">Resume Ready</span>
                    <span class="bg-slate-100 px-2.5 py-1 rounded">Profile Optimization</span>
                  </div>
                </div>

                <!-- Bento Card 2: Career Growth -->
                <div class="glass-card-premium p-6 rounded-2xl border border-slate-200/80 bg-white hover:border-secondary/20 shadow-sm flex flex-col justify-between space-y-4">
                  <div class="space-y-2">
                    <span class="material-symbols-outlined text-secondary text-3xl font-bold">trending_up</span>
                    <h4 class="text-lg font-headline font-bold text-primary">Career Path</h4>
                    <p class="text-slate-500 text-xs leading-relaxed font-body font-medium">
                      Acquire trust and secure direct interview references with local businesses.
                    </p>
                  </div>
                  <div class="text-[10px] text-accent font-black uppercase flex items-center gap-1 font-headline">
                    <span class="material-symbols-outlined text-xs">verified</span> verified pathways
                  </div>
                </div>

                <!-- Bento Card 3: Reference Letter -->
                <div class="glass-card-premium p-6 rounded-2xl border border-slate-200/80 bg-white hover:border-secondary/20 shadow-sm flex flex-col justify-between space-y-4">
                  <div class="space-y-2">
                    <span class="material-symbols-outlined text-secondary text-3xl font-bold">recommend</span>
                    <h4 class="text-lg font-headline font-bold text-primary">Reference Letter</h4>
                    <p class="text-slate-500 text-xs leading-relaxed font-body font-medium">
                      High-performing interns (evaluating A/A+ scores) qualify for customized letters of recommendation.
                    </p>
                  </div>
                  <span class="text-[10px] text-slate-400 font-semibold block">Subject to Evaluation</span>
                </div>

                <!-- Bento Card 4: Practical Exposure -->
                <div class="md:col-span-2 glass-card-premium p-6 rounded-2xl border border-slate-200/80 bg-white hover:border-secondary/20 shadow-sm flex flex-col justify-between space-y-4">
                  <div class="space-y-2">
