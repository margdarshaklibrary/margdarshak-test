          <div class="text-center space-y-2">
            <span class="text-xs font-black uppercase text-secondary tracking-widest block font-headline">Professional Development</span>
            <h2 class="text-2xl md:text-3xl font-headline font-black text-primary">Other Professional Internships</h2>
