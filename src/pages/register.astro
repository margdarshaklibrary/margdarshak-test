---
import Layout from '../layouts/Layout.astro';
import { getCourses, getInternships } from '../data/db.js';

const courses = await getCourses();
const internships = await getInternships();
---

<Layout 
  title="Register for Courses & Internships — Margdarshak Shikshan Sansthan, Darbhanga" 
  description="Register for a course or internship at Margdarshak Shikshan Sansthan. Secure your seat online for Web Development, Tally, GST, Digital Marketing & more for just ₹1,000/month with 100% refund."
  ogImage="/assets/register_hero.jpg"
>
  
  <!-- Premium SaaS + EdTech Hero Section -->
  <section class="hero-gradient text-white py-16 md:py-24 relative overflow-hidden">
    <!-- Background glows -->
    <div class="glow-blob bg-secondary/15 w-[350px] h-[350px] top-10 left-10 animate-float-slow" aria-hidden="true"></div>
    <div class="glow-blob bg-accent/15 w-[400px] h-[400px] -bottom-20 right-10 animate-float-medium" aria-hidden="true"></div>

    <div class="max-w-[1440px] mx-auto px-4 md:px-6 relative z-10 grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
      
      <!-- Hero Text Column -->
      <div class="lg:col-span-7 space-y-6 text-left">
        <div class="inline-flex items-center gap-2 bg-white/10 border border-white/15 px-4 py-1.5 rounded-full text-xs font-bold uppercase tracking-wider text-accent">
          <span class="material-symbols-outlined text-sm font-bold animate-ping">radio_button_checked</span>
          Admissions Open
        </div>
        <h1 class="text-4xl md:text-6xl font-headline font-black leading-tight tracking-tight">
          Admissions Open.<br />
          Build Practical Skills.<br />
          <span class="text-gradient-white-orange">Start Your Career.</span>
        </h1>
        <p class="text-slate-300 max-w-2xl text-base md:text-lg leading-relaxed font-body">
          Kickstart your professional journey with our industry-driven programs. Experience hands-on practical learning, integrated internship opportunities, and complete career support—all at an affordable fee of just <span class="text-white font-bold border-b border-accent/30 pb-0.5">₹1,000/month</span>.
        </p>
        
        <!-- Premium Feature Cards -->
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 pt-4">
          <!-- Hybrid Learning -->
          <div class="bg-white/5 border border-white/10 hover:border-white/20 p-4 rounded-2xl flex items-center gap-3 transition-all duration-300 shadow-glass group hover:bg-white/10 hover:-translate-y-1">
            <div class="w-8 h-8 rounded-full bg-secondary/20 flex items-center justify-center text-secondary shrink-0 group-hover:scale-110 transition-transform">
              <span class="material-symbols-outlined text-base font-bold">check</span>
            </div>
            <span class="text-sm font-bold text-white leading-tight font-headline">Hybrid Learning</span>
          </div>
          <!-- 100% Fee Refund -->
          <div class="bg-white/5 border border-white/10 hover:border-white/20 p-4 rounded-2xl flex items-center gap-3 transition-all duration-300 shadow-glass group hover:bg-white/10 hover:-translate-y-1">
            <div class="w-8 h-8 rounded-full bg-accent/20 flex items-center justify-center text-accent shrink-0 group-hover:scale-110 transition-transform">
              <span class="material-symbols-outlined text-base font-bold">check</span>
            </div>
            <span class="text-sm font-bold text-white leading-tight font-headline">100% Fee Refund</span>
          </div>
          <!-- Government Registered -->
          <div class="bg-white/5 border border-white/10 hover:border-white/20 p-4 rounded-2xl flex items-center gap-3 transition-all duration-300 shadow-glass group hover:bg-white/10 hover:-translate-y-1">
            <div class="w-8 h-8 rounded-full bg-secondary/20 flex items-center justify-center text-secondary shrink-0 group-hover:scale-110 transition-transform">
              <span class="material-symbols-outlined text-base font-bold">check</span>
            </div>
            <span class="text-sm font-bold text-white leading-tight font-headline">Govt. Registered</span>
          </div>
        </div>
      </div>

      <!-- Hero Visual Column (Displays attached image) -->
      <div class="lg:col-span-5 flex justify-center items-center">
        <div class="relative w-full max-w-md lg:max-w-none">
          <div class="absolute inset-0 bg-gradient-to-tr from-secondary/30 to-accent/30 rounded-3xl blur-2xl opacity-30 animate-pulse-glow"></div>
          <picture>
            <img 
              src="/assets/register_hero.jpg" 
              alt="Margdarshak Shikshan Sansthan admissions — students registering for courses" 
              class="w-full h-auto object-cover rounded-3xl shadow-2xl border border-white/10 relative z-10 animate-float-slow hover:scale-[1.02] transition-transform duration-500"
              loading="eager"
              fetchpriority="high"
              decoding="async"
              width="600"
              height="400"
            />
          </picture>
        </div>
      </div>

    </div>
  </section>

  <!-- Registration Section -->
  <section id="registration-section" class="py-16 md:py-24 bg-slate-50 relative" style="scroll-margin-top: 80px;">
    <div class="max-w-[1440px] mx-auto px-4 md:px-6 grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">
      
      <!-- Left Column: Trust-Building & Social Proof -->
      <div class="lg:col-span-5 space-y-6">
        
        <!-- Merged Premium Info Card -->
        <div class="relative overflow-hidden bg-white border border-slate-100 p-6 sm:p-8 rounded-3xl shadow-premium hover:shadow-premium-hover transition-all duration-300 space-y-6 hover:-translate-y-1">
          <!-- Background decorative glows for premium feel -->
          <div class="absolute -right-16 -bottom-16 w-48 h-48 bg-secondary/5 rounded-full blur-[60px] pointer-events-none"></div>
          <div class="absolute -left-16 -top-16 w-48 h-48 bg-accent/5 rounded-full blur-[60px] pointer-events-none"></div>
          
          <div class="relative z-10 space-y-6">
            <!-- Header -->
            <div class="space-y-2">
              <span class="inline-flex items-center gap-1.5 bg-secondary/10 border border-secondary/20 px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider text-secondary">
                <span class="material-symbols-outlined text-xs">verified_user</span> Why Join Margdarshak?
              </span>
              <h3 class="text-xl sm:text-2xl font-headline font-black text-primary tracking-tight">
                Empowering Your Career Journey
              </h3>
            </div>

            <!-- Features list -->
            <div class="space-y-5">
              <!-- Feature 1 -->
              <div class="flex items-start gap-4">
                <div class="p-2.5 bg-emerald-50 rounded-2xl text-emerald-600 shrink-0">
                  <span class="material-symbols-outlined text-xl font-bold">check_circle</span>
                </div>
                <div>
                  <h4 class="font-headline font-bold text-primary text-base">Government Recognized Credentials</h4>
                  <p class="text-slate-500 text-xs mt-1 leading-relaxed font-body">Certifications registered under MCA (Govt. of India), recognized nationwide for employment.</p>
                </div>
              </div>
              
              <!-- Feature 2 -->
              <div class="flex items-start gap-4">
                <div class="p-2.5 bg-emerald-50 rounded-2xl text-emerald-600 shrink-0">
                  <span class="material-symbols-outlined text-xl font-bold">check_circle</span>
                </div>
                <div>
                  <h4 class="font-headline font-bold text-primary text-base">100% Practical Training</h4>
                  <p class="text-slate-500 text-xs mt-1 leading-relaxed font-body">Learn by filing actual tax forms, building actual websites, and working with live accounting logs.</p>
                </div>
              </div>
              
              <!-- Feature 3 -->
              <div class="flex items-start gap-4">
                <div class="p-2.5 bg-emerald-50 rounded-2xl text-emerald-600 shrink-0">
                  <span class="material-symbols-outlined text-xl font-bold">check_circle</span>
                </div>
                <div>
                  <h4 class="font-headline font-bold text-primary text-base">Active Job Placement Assistance</h4>
                  <p class="text-slate-500 text-xs mt-1 leading-relaxed font-body">Interview preparation, direct resume routing, and hiring partnership drives.</p>
                </div>
              </div>

              <!-- Divider -->
              <div class="border-t border-slate-100 my-4"></div>

              <!-- Refund Offer Integration -->
              <div class="bg-gradient-to-br from-[#071426] via-[#0d223e] to-[#071426] border border-slate-800/80 p-5 rounded-2xl text-white shadow-md relative overflow-hidden">
                <div class="absolute -right-8 -bottom-8 w-32 h-32 bg-secondary/15 rounded-full blur-[40px] pointer-events-none"></div>
                <div class="relative z-10 space-y-3">
                  <div class="flex justify-between items-start">
                    <span class="inline-flex items-center gap-1 bg-secondary/20 border border-secondary/30 px-2.5 py-0.5 rounded-full text-[9px] font-bold uppercase tracking-wider text-white">
                      <span class="material-symbols-outlined text-[10px]">savings</span> Scholarship & Refund Policy
                    </span>
                  </div>
                  
                  <div class="space-y-1">
                    <h5 class="text-xl font-headline font-black text-white flex items-baseline gap-1.5">
                      90% <span class="text-accent text-sm font-bold">Attendance</span>
                    </h5>
                    <p class="text-lg font-headline font-extrabold text-gradient-white-orange leading-none">
                      = 100% Fee Refund Opportunity
                    </p>
                  </div>
                  
                  <p class="text-slate-300 text-xs leading-relaxed font-body">
                    Attend 90% of classes, submit assignments on schedule, and get your entire program fee refunded upon completion!
                  </p>
                </div>
              </div>

            </div>
          </div>
        </div>

      </div>

      <!-- Right Column: Premium Multi-Step Form Funnel (Sticky on Desktop) -->
      <div class="lg:col-span-7 lg:sticky lg:top-24 bg-white p-4 sm:p-6 md:p-10 rounded-3xl sm:rounded-4xl border border-slate-100 shadow-premium relative space-y-6 sm:space-y-8 self-start">
        
        <!-- Form Header -->
        <div class="space-y-1">
          <h3 class="text-2xl font-headline font-black text-primary">Admission Application</h3>
          <p class="text-slate-400 text-xs font-body">Please follow the steps to complete your seat reservation.</p>
        </div>

        <!-- Funnel Step Progress Indicator -->
        <div class="relative py-4">
          <div class="absolute top-1/2 left-0 right-0 h-0.5 bg-slate-100 -translate-y-1/2 z-0"></div>
          <div class="absolute top-1/2 left-0 h-0.5 bg-secondary -translate-y-1/2 z-0 transition-all duration-500" id="progress-bar-line" style="width: 0%;"></div>
          
          <div class="relative z-10 flex justify-between">
            <!-- Step 1 Dot -->
            <div class="flex flex-col items-center gap-2">
              <div class="w-9 h-9 rounded-full bg-secondary text-white font-bold text-xs flex items-center justify-center transition-all duration-300 ring-4 ring-secondary/20 shadow-md" id="step-dot-1">
                1
              </div>
              <span class="text-[9px] xs:text-[10px] font-bold text-secondary uppercase tracking-wider" id="step-label-1">Personal</span>
            </div>
            
            <!-- Step 2 Dot -->
            <div class="flex flex-col items-center gap-2">
              <div class="w-9 h-9 rounded-full bg-slate-100 text-slate-400 font-bold text-xs flex items-center justify-center transition-all duration-300 ring-4 ring-transparent" id="step-dot-2">
                2
              </div>
              <span class="text-[9px] xs:text-[10px] font-bold text-slate-400 uppercase tracking-wider" id="step-label-2">Program</span>
            </div>
            
            <!-- Step 3 Dot -->
            <div class="flex flex-col items-center gap-2">
              <div class="w-9 h-9 rounded-full bg-slate-100 text-slate-400 font-bold text-xs flex items-center justify-center transition-all duration-300 ring-4 ring-transparent" id="step-dot-3">
                3
              </div>
              <span class="text-[9px] xs:text-[10px] font-bold text-slate-400 uppercase tracking-wider" id="step-label-3">Review</span>
            </div>
          </div>
        </div>

        <form id="registration-funnel-form" class="space-y-6">
          
          <!-- STEP 1: Personal Details -->
          <div id="form-step-1" class="space-y-6 transition-all duration-300">
            <h4 class="font-headline font-bold text-slate-800 text-lg border-b border-slate-100 pb-2">Step 1: Contact Details</h4>
            
            <!-- Full Name -->
            <div class="space-y-2">
              <label class="text-xs font-bold text-slate-500 uppercase tracking-wider block font-headline" for="name">Full Name</label>
              <div class="relative">
                <span class="material-symbols-outlined text-slate-400 absolute left-4 top-1/2 -translate-y-1/2 text-lg">person</span>
                <input 
                  id="name" 
                  class="w-full pl-12 pr-4 py-3.5 rounded-2xl border border-slate-200 bg-slate-50/50 focus:border-secondary focus:bg-white focus:ring-4 focus:ring-secondary/5 focus:outline-none text-sm transition-all font-body font-medium" 
                  placeholder="Enter your full name" 
                  type="text" 
                  required 
                />
              </div>
              <p class="text-xs text-rose-500 hidden font-body" id="error-name">Please enter your name</p>
            </div>

            <!-- Contact Grid -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <!-- Mobile -->
              <div class="space-y-2">
                <label class="text-xs font-bold text-slate-500 uppercase tracking-wider block font-headline" for="mobile">Mobile Number</label>
                <div class="relative">
                  <span class="material-symbols-outlined text-slate-400 absolute left-4 top-1/2 -translate-y-1/2 text-lg">call</span>
                  <input 
                    id="mobile" 
                    class="w-full pl-12 pr-4 py-3.5 rounded-2xl border border-slate-200 bg-slate-50/50 focus:border-secondary focus:bg-white focus:ring-4 focus:ring-secondary/5 focus:outline-none text-sm transition-all font-body font-medium" 
                    placeholder="10-digit number" 
                    type="tel" 
                    pattern="[0-9]{10}"
                    required 
                  />
                </div>
                <p class="text-xs text-rose-500 hidden font-body" id="error-mobile">Enter a valid 10-digit number</p>
              </div>

              <!-- WhatsApp -->
              <div class="space-y-2">
                <div class="flex justify-between items-center">
                  <label class="text-xs font-bold text-slate-500 uppercase tracking-wider block font-headline" for="whatsapp">WhatsApp Number</label>
                  <label class="inline-flex items-center gap-1 cursor-pointer text-[10px] text-secondary font-bold font-headline">
                    <input type="checkbox" id="sync-whatsapp" class="rounded border-slate-300 text-secondary focus:ring-secondary" checked />
                    Same as Mobile
                  </label>
                </div>
                <div class="relative">
                  <span class="material-symbols-outlined text-slate-400 absolute left-4 top-1/2 -translate-y-1/2 text-lg">chat</span>
                  <input 
                    id="whatsapp" 
                    class="w-full pl-12 pr-4 py-3.5 rounded-2xl border border-slate-200 bg-slate-50/50 focus:border-secondary focus:bg-white focus:ring-4 focus:ring-secondary/5 focus:outline-none text-sm transition-all font-body font-medium" 
                    placeholder="WhatsApp contact" 
                    type="tel" 
                    pattern="[0-9]{10}"
                    required 
                  />
                </div>
                <p class="text-xs text-rose-500 hidden font-body" id="error-whatsapp">Enter a valid WhatsApp number</p>
              </div>
            </div>

            <!-- Email -->
            <div class="space-y-2">
              <label class="text-xs font-bold text-slate-500 uppercase tracking-wider block font-headline" for="email">Email Address</label>
              <div class="relative">
                <span class="material-symbols-outlined text-slate-400 absolute left-4 top-1/2 -translate-y-1/2 text-lg">mail</span>
                <input 
                  id="email" 
                  class="w-full pl-12 pr-4 py-3.5 rounded-2xl border border-slate-200 bg-slate-50/50 focus:border-secondary focus:bg-white focus:ring-4 focus:ring-secondary/5 focus:outline-none text-sm transition-all font-body font-medium" 
                  placeholder="name@example.com" 
                  type="email" 
                  required 
                />
              </div>
              <p class="text-xs text-rose-500 hidden font-body" id="error-email">Enter a valid email address</p>
            </div>

            <!-- Next button -->
            <div class="pt-4">
              <button 
                type="button" 
                id="next-btn-1" 
                class="w-full py-4 btn-brand-gradient text-white font-bold rounded-2xl flex items-center justify-center gap-2 hover:scale-[1.01] active:scale-[0.99] transition-all shadow-lg font-headline"
              >
                Continue to Program Selection
                <span class="material-symbols-outlined text-sm font-bold">arrow_forward</span>
              </button>
            </div>
          </div>

          <!-- STEP 2: Program Selection -->
          <div id="form-step-2" class="space-y-6 hidden transition-all duration-300">
            <h4 class="font-headline font-bold text-slate-800 text-lg border-b border-slate-100 pb-2">Step 2: Choose Program & Mode</h4>

            <!-- Program Type Tabs -->
            <div class="space-y-2">
              <label class="text-xs font-bold text-slate-400 uppercase tracking-wider block font-headline">Program Type</label>
              <div class="grid grid-cols-2 gap-2 bg-slate-100 p-1.5 rounded-2xl">
                <button 
                  type="button" 
                  id="tab-course" 
                  class="py-3 px-4 rounded-xl font-bold font-headline text-xs md:text-sm text-center transition-all bg-white text-primary shadow-sm"
                >
                  Job-Oriented Course
                </button>
                <button 
                  type="button" 
                  id="tab-internship" 
                  class="py-3 px-4 rounded-xl font-bold font-headline text-xs md:text-sm text-center transition-all text-slate-500 hover:text-slate-700"
                >
                  1-Month Internship
                </button>
              </div>
            </div>

            <!-- Selection Cards Container -->
            <div class="space-y-3">
              <label class="text-xs font-bold text-slate-400 uppercase tracking-wider block font-headline">Select Your Specific Track</label>
              
              <!-- Courses Card Grid -->
              <div id="grid-courses" class="grid grid-cols-1 md:grid-cols-2 gap-4 max-h-[300px] overflow-y-auto pr-1">
                {courses.map(course => (
                  <div 
                    class="program-card border border-slate-200 bg-white p-4 rounded-2xl cursor-pointer hover:border-secondary hover:shadow-md transition-all relative flex flex-col justify-between gap-3"
                    data-id={course.id}
                    data-type="course"
                    data-name={course.name}
                    data-duration={course.duration}
                    data-fee={course.fee}
                    data-category={course.tags[0] || 'Job Training'}
                  >
                    <!-- Select indicator dot -->
                    <div class="absolute top-3 right-3 w-5 h-5 rounded-full border border-slate-300 flex items-center justify-center select-dot bg-white">
                      <span class="material-symbols-outlined text-xs text-white font-bold select-icon hidden">check</span>
                    </div>

                    <div class="space-y-1 pr-6">
                      <span class="inline-block bg-primary/5 text-primary text-[10px] font-bold px-2 py-0.5 rounded-md uppercase tracking-wide font-headline">
                        {course.tags[0] || 'Job Training'}
                      </span>
                      <h5 class="font-headline font-bold text-primary text-sm line-clamp-1">{course.name}</h5>
                    </div>

                    <div class="flex justify-between items-center text-xs border-t border-slate-100 pt-2 text-slate-500 font-body">
                      <div class="flex items-center gap-1">
                        <span class="material-symbols-outlined text-sm">schedule</span>
                        <span>{course.duration}</span>
                      </div>
                      <div class="font-bold text-primary">
                        {course.fee}
                      </div>
                    </div>
                  </div>
                ))}
              </div>

              <!-- Internships Card Grid -->
              <div id="grid-internships" class="grid grid-cols-1 md:grid-cols-2 gap-4 max-h-[300px] overflow-y-auto pr-1 hidden">
                {internships.map(internship => (
                  <div 
                    class="program-card border border-slate-200 bg-white p-4 rounded-2xl cursor-pointer hover:border-secondary hover:shadow-md transition-all relative flex flex-col justify-between gap-3"
                    data-id={internship.id}
                    data-type="internship"
                    data-name={internship.name}
                    data-duration={internship.duration}
                    data-fee={internship.fee}
                    data-category={internship.tags[0] || 'Internship'}
                  >
                    <!-- Select indicator dot -->
                    <div class="absolute top-3 right-3 w-5 h-5 rounded-full border border-slate-300 flex items-center justify-center select-dot bg-white">
                      <span class="material-symbols-outlined text-xs text-white font-bold select-icon hidden">check</span>
                    </div>

                    <div class="space-y-1 pr-6">
                      <span class="inline-block bg-secondary/5 text-secondary text-[10px] font-bold px-2 py-0.5 rounded-md uppercase tracking-wide font-headline">
                        {internship.tags[0] || 'Internship'}
                      </span>
                      <h5 class="font-headline font-bold text-primary text-sm line-clamp-1">{internship.name}</h5>
                    </div>

                    <div class="flex justify-between items-center text-xs border-t border-slate-100 pt-2 text-slate-500 font-body">
                      <div class="flex items-center gap-1">
                        <span class="material-symbols-outlined text-sm">schedule</span>
                        <span>{internship.duration}</span>
                      </div>
                      <div class="font-bold text-primary">
                        {internship.fee}
                      </div>
                    </div>
                  </div>
                ))}
              </div>

              <p class="text-xs text-rose-500 hidden font-body" id="error-program">Please select a program track to continue</p>
            </div>

            <!-- Learning Mode Selection -->
            <div class="space-y-2">
              <label class="text-xs font-bold text-slate-400 uppercase tracking-wider block font-headline" for="learning-mode">Learning Mode</label>
              <select id="learning-mode" class="w-full px-4 py-4 rounded-xl border border-slate-200 bg-slate-50/50 focus:border-secondary focus:bg-white focus:ring-4 focus:ring-secondary/5 focus:outline-none text-sm transition-all font-body font-medium">
                <option value="Hybrid">Hybrid (Classroom & Live Online)</option>
                <option value="Offline">Offline Center (Darbhanga Labs)</option>
                <option value="Online">Online Classes</option>
              </select>
            </div>

            <!-- Action buttons -->
            <div class="flex flex-col sm:flex-row items-center gap-3 pt-4">
              <button 
                type="button" 
                id="back-btn-2" 
                class="w-full sm:w-1/3 py-4 border border-slate-200 text-slate-500 font-bold rounded-2xl hover:bg-slate-50 hover:text-slate-700 active:scale-[0.99] transition-all flex items-center justify-center gap-1.5 text-xs md:text-sm font-headline"
              >
                <span class="material-symbols-outlined text-sm">arrow_back</span>
                Back
              </button>
              
              <button 
                type="button" 
                id="next-btn-2" 
                class="w-full sm:w-2/3 py-4 btn-brand-gradient text-white font-bold rounded-2xl flex items-center justify-center gap-2 hover:scale-[1.01] active:scale-[0.99] transition-all shadow-lg text-xs md:text-sm font-headline"
              >
                Proceed to Confirmation
                <span class="material-symbols-outlined text-sm font-bold">arrow_forward</span>
              </button>
            </div>
          </div>

          <!-- STEP 3: Review & Submit -->
          <div id="form-step-3" class="space-y-6 hidden transition-all duration-300">
            <h4 class="font-headline font-bold text-slate-800 text-lg border-b border-slate-100 pb-2">Step 3: Review Details & Submit</h4>
            
            <div class="bg-slate-50 border border-slate-200/60 rounded-3xl p-4 sm:p-6 space-y-4">
              <div class="flex justify-between items-start border-b border-slate-200/50 pb-3">
                <h5 class="font-headline font-bold text-primary text-sm flex items-center gap-2">
                  <span class="material-symbols-outlined text-slate-500 text-base">person</span>
                  Applicant
                </h5>
                <button type="button" class="text-xs text-secondary font-bold hover:underline edit-step-1 font-headline">Edit</button>
              </div>
              <div class="grid grid-cols-2 gap-4 text-xs font-body">
                <div class="space-y-0.5">
                  <span class="text-slate-400 font-bold uppercase text-[9px] tracking-wider font-headline">Full Name</span>
                  <p class="font-semibold text-slate-800" id="review-name">-</p>
                </div>
                <div class="space-y-0.5">
                  <span class="text-slate-400 font-bold uppercase text-[9px] tracking-wider font-headline">Email Address</span>
                  <p class="font-semibold text-slate-800 truncate" id="review-email">-</p>
                </div>
                <div class="space-y-0.5">
