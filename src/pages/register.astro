  <!-- Client-side Dynamic Multi-Step Form Wizard Handling -->
  <script is:inline define:vars={{ courses, internships }}>
    document.addEventListener('DOMContentLoaded', () => {
      // Data variables
      const coursesData = courses;
      const internshipsData = internships;

      // DOM Elements
      const step1El = document.getElementById('form-step-1');
      const step2El = document.getElementById('form-step-2');
      const step3El = document.getElementById('form-step-3');

      // Buttons
      const nextBtn1 = document.getElementById('next-btn-1');
      const nextBtn2 = document.getElementById('next-btn-2');
      const backBtn2 = document.getElementById('back-btn-2');
      const backBtn3 = document.getElementById('back-btn-3');
      const submitBtn = document.getElementById('submit-btn');

      // Progress bars
      const progressBarLine = document.getElementById('progress-bar-line');
      const stepDot1 = document.getElementById('step-dot-1');
      const stepDot2 = document.getElementById('step-dot-2');
      const stepDot3 = document.getElementById('step-dot-3');
      const stepLabel1 = document.getElementById('step-label-1');
      const stepLabel2 = document.getElementById('step-label-2');
      const stepLabel3 = document.getElementById('step-label-3');

      // Inputs
      const nameInput = document.getElementById('name');
      const mobileInput = document.getElementById('mobile');
      const whatsappInput = document.getElementById('whatsapp');
      const emailInput = document.getElementById('email');
      const syncWhatsappCheck = document.getElementById('sync-whatsapp');
      const learningModeInput = document.getElementById('learning-mode');
      const messageInput = document.getElementById('message');

      // Error messages
      const errorName = document.getElementById('error-name');
      const errorMobile = document.getElementById('error-mobile');
      const errorWhatsapp = document.getElementById('error-whatsapp');
      const errorEmail = document.getElementById('error-email');
      const errorProgram = document.getElementById('error-program');

      // Tabs & Selection Cards
      const tabCourse = document.getElementById('tab-course');
      const tabInternship = document.getElementById('tab-internship');
      const gridCourses = document.getElementById('grid-courses');
      const gridInternships = document.getElementById('grid-internships');
      const programCards = document.querySelectorAll('.program-card');

      // Selected values variables
      let selectedProgramId = '';
      let selectedProgramType = 'course'; // default
      let selectedProgramName = '';
      let selectedProgramDuration = '';
      let selectedProgramFee = '';

      // Review Fields
      const reviewName = document.getElementById('review-name');
      const reviewEmail = document.getElementById('review-email');
      const reviewMobile = document.getElementById('review-mobile');
      const reviewWhatsapp = document.getElementById('review-whatsapp');
      const reviewProgram = document.getElementById('review-program');
      const reviewProgramCost = document.getElementById('review-program-cost');
      const reviewMode = document.getElementById('review-mode');

      // -------------------------------
      // Sync WhatsApp with Mobile
      // -------------------------------
      function handleSyncWhatsapp() {
        if (syncWhatsappCheck && syncWhatsappCheck.checked) {
          whatsappInput.value = mobileInput.value;
          whatsappInput.setAttribute('disabled', 'true');
        } else {
          whatsappInput.removeAttribute('disabled');
        }
      }

      if (syncWhatsappCheck && mobileInput && whatsappInput) {
        mobileInput.addEventListener('input', () => {
          if (syncWhatsappCheck.checked) {
            whatsappInput.value = mobileInput.value;
          }
        });
        syncWhatsappCheck.addEventListener('change', handleSyncWhatsapp);
        handleSyncWhatsapp(); // Initial run
      }

      // -------------------------------
      // Step Wizard Navigation logic
      // -------------------------------
      function setProgress(step) {
        if (step === 1) {
          progressBarLine.style.width = '0%';
          
          stepDot1.className = 'w-9 h-9 rounded-full bg-secondary text-white font-bold text-xs flex items-center justify-center ring-4 ring-secondary/20 shadow-md transition-all duration-300';
          stepDot2.className = 'w-9 h-9 rounded-full bg-slate-100 text-slate-400 font-bold text-xs flex items-center justify-center ring-4 ring-transparent transition-all duration-300';
          stepDot3.className = 'w-9 h-9 rounded-full bg-slate-100 text-slate-400 font-bold text-xs flex items-center justify-center ring-4 ring-transparent transition-all duration-300';
          
          stepLabel1.className = 'text-[10px] font-bold text-secondary uppercase tracking-wider';
          stepLabel2.className = 'text-[10px] font-bold text-slate-400 uppercase tracking-wider';
          stepLabel3.className = 'text-[10px] font-bold text-slate-400 uppercase tracking-wider';
        } else if (step === 2) {
          progressBarLine.style.width = '50%';
          
          stepDot1.className = 'w-9 h-9 rounded-full bg-secondary text-white font-bold text-xs flex items-center justify-center ring-4 ring-secondary/10 shadow-md transition-all duration-300';
          stepDot2.className = 'w-9 h-9 rounded-full bg-secondary text-white font-bold text-xs flex items-center justify-center ring-4 ring-secondary/20 shadow-md transition-all duration-300';
          stepDot3.className = 'w-9 h-9 rounded-full bg-slate-100 text-slate-400 font-bold text-xs flex items-center justify-center ring-4 ring-transparent transition-all duration-300';
          
          stepLabel1.className = 'text-[10px] font-bold text-secondary uppercase tracking-wider';
          stepLabel2.className = 'text-[10px] font-bold text-secondary uppercase tracking-wider';
          stepLabel3.className = 'text-[10px] font-bold text-slate-400 uppercase tracking-wider';
        } else if (step === 3) {
          progressBarLine.style.width = '100%';
          
          stepDot1.className = 'w-9 h-9 rounded-full bg-secondary text-white font-bold text-xs flex items-center justify-center ring-4 ring-secondary/10 shadow-md transition-all duration-300';
          stepDot2.className = 'w-9 h-9 rounded-full bg-secondary text-white font-bold text-xs flex items-center justify-center ring-4 ring-secondary/10 shadow-md transition-all duration-300';
          stepDot3.className = 'w-9 h-9 rounded-full bg-secondary text-white font-bold text-xs flex items-center justify-center ring-4 ring-secondary/20 shadow-md transition-all duration-300';
          
          stepLabel1.className = 'text-[10px] font-bold text-secondary uppercase tracking-wider';
          stepLabel2.className = 'text-[10px] font-bold text-secondary uppercase tracking-wider';
          stepLabel3.className = 'text-[10px] font-bold text-secondary uppercase tracking-wider';
        }
      }

      function showStep(step) {
        setProgress(step);
        if (step === 1) {
          step1El.classList.remove('hidden');
          step1El.classList.add('step-active-fade');
          step2El.classList.add('hidden');
          step2El.classList.remove('step-active-fade');
          step3El.classList.add('hidden');
          step3El.classList.remove('step-active-fade');
        } else if (step === 2) {
          step1El.classList.add('hidden');
          step1El.classList.remove('step-active-fade');
          step2El.classList.remove('hidden');
          step2El.classList.add('step-active-fade');
          step3El.classList.add('hidden');
          step3El.classList.remove('step-active-fade');
        } else if (step === 3) {
          step1El.classList.add('hidden');
          step1El.classList.remove('step-active-fade');
          step2El.classList.add('hidden');
          step2El.classList.remove('step-active-fade');
          step3El.classList.remove('hidden');
          step3El.classList.add('step-active-fade');
          updateReviewSection();
        }
        // Smooth scroll to the registration section (not top of page)
        const registrationSection = document.getElementById('registration-section');
        if (registrationSection) {
          registrationSection.scrollIntoView({
            behavior: 'smooth',
            block: 'start'
          });
        }
      }

      // Step 1 Validation
      function validateStep1() {
        let isValid = true;
        
        if (!nameInput.value.trim()) {
          errorName.classList.remove('hidden');
          isValid = false;
        } else {
          errorName.classList.add('hidden');
        }

        const phoneRegex = /^[0-9]{10}$/;
        if (!phoneRegex.test(mobileInput.value)) {
          errorMobile.classList.remove('hidden');
          isValid = false;
        } else {
          errorMobile.classList.add('hidden');
        }

        if (!syncWhatsappCheck.checked && !phoneRegex.test(whatsappInput.value)) {
          errorWhatsapp.classList.remove('hidden');
          isValid = false;
        } else {
          errorWhatsapp.classList.add('hidden');
        }

        const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
        if (!emailRegex.test(emailInput.value)) {
          errorEmail.classList.remove('hidden');
          isValid = false;
        } else {
          errorEmail.classList.add('hidden');
        }

        return isValid;
      }

      nextBtn1.addEventListener('click', () => {
        if (validateStep1()) {
          showStep(2);
        }
      });

      // Step 2 Validation
      function validateStep2() {
        if (!selectedProgramId) {
          errorProgram.classList.remove('hidden');
          return false;
        }
        errorProgram.classList.add('hidden');
        return true;
      }

      nextBtn2.addEventListener('click', () => {
        if (validateStep2()) {
          showStep(3);
        }
      });

      backBtn2.addEventListener('click', () => showStep(1));
      backBtn3.addEventListener('click', () => showStep(2));

      // Edit buttons on step 3
      document.querySelectorAll('.edit-step-1').forEach(b => b.addEventListener('click', () => showStep(1)));
      document.querySelectorAll('.edit-step-2').forEach(b => b.addEventListener('click', () => showStep(2)));

      // -------------------------------
      // Tabs and Card Selection logic
      // -------------------------------
      function selectProgramTab(type) {
        selectedProgramType = type;
        if (type === 'course') {
          tabCourse.className = 'py-3 px-4 rounded-xl font-bold font-headline text-xs md:text-sm text-center transition-all bg-white text-primary shadow-sm';
          tabInternship.className = 'py-3 px-4 rounded-xl font-bold font-headline text-xs md:text-sm text-center transition-all text-slate-500 hover:text-slate-700';
          gridCourses.classList.remove('hidden');
          gridInternships.classList.add('hidden');
        } else {
          tabInternship.className = 'py-3 px-4 rounded-xl font-bold font-headline text-xs md:text-sm text-center transition-all bg-white text-primary shadow-sm';
          tabCourse.className = 'py-3 px-4 rounded-xl font-bold font-headline text-xs md:text-sm text-center transition-all text-slate-500 hover:text-slate-700';
          gridInternships.classList.remove('hidden');
          gridCourses.classList.add('hidden');
        }
      }

      tabCourse.addEventListener('click', () => selectProgramTab('course'));
      tabInternship.addEventListener('click', () => selectProgramTab('internship'));

      // Highlight program selection card
      function selectCard(cardEl) {
        // Remove active state from all cards
        programCards.forEach(card => {
          card.classList.remove('border-accent', 'bg-accent/5', 'ring-2', 'ring-accent');
          const dot = card.querySelector('.select-dot');
          const icon = card.querySelector('.select-icon');
          if (dot) dot.className = 'absolute top-3 right-3 w-5 h-5 rounded-full border border-slate-300 flex items-center justify-center select-dot bg-white';
          if (icon) icon.classList.add('hidden');
        });

        // Set active state on target card
        cardEl.classList.add('border-accent', 'bg-accent/5', 'ring-2', 'ring-accent');
        const dot = cardEl.querySelector('.select-dot');
        const icon = cardEl.querySelector('.select-icon');
        if (dot) dot.className = 'absolute top-3 right-3 w-5 h-5 rounded-full border border-accent bg-accent flex items-center justify-center select-dot shadow-md shadow-accent/10';
        if (icon) icon.classList.remove('hidden');

        // Store selected properties
        selectedProgramId = cardEl.getAttribute('data-id');
        selectedProgramType = cardEl.getAttribute('data-type');
        selectedProgramName = cardEl.getAttribute('data-name');
        selectedProgramDuration = cardEl.getAttribute('data-duration');
        selectedProgramFee = cardEl.getAttribute('data-fee');

        errorProgram.classList.add('hidden');
      }

      programCards.forEach(card => {
        card.addEventListener('click', () => {
          selectCard(card);
        });
      });

      // -------------------------------
      // Populate review step data
      // -------------------------------
      function updateReviewSection() {
        reviewName.textContent = nameInput.value.trim();
        reviewEmail.textContent = emailInput.value.trim();
        reviewMobile.textContent = mobileInput.value.trim();
        reviewWhatsapp.textContent = syncWhatsappCheck.checked ? mobileInput.value.trim() : whatsappInput.value.trim();
        reviewProgram.textContent = selectedProgramName;
        reviewProgramCost.textContent = `${selectedProgramDuration} (${selectedProgramFee})`;
        
        const modeText = learningModeInput.options[learningModeInput.selectedIndex].textContent;
        reviewMode.textContent = modeText;
      }

      // -------------------------------
      // URL Params prefill parser
      // -------------------------------
      const params = new URLSearchParams(window.location.search);
      const paramProgram = params.get('program'); // 'course' or 'internship'
      const paramName = params.get('name');
      const paramMobile = params.get('mobile');
      const paramMode = params.get('mode');

      if (paramName) nameInput.value = paramName;
      if (paramMobile) {
        mobileInput.value = paramMobile;
        whatsappInput.value = paramMobile;
      }
      if (paramMode) learningModeInput.value = paramMode;

      // Handle URL pre-selection
      if (paramProgram === 'internship') {
        selectProgramTab('internship');
        const internshipId = params.get('internship');
        if (internshipId) {
          const targetCard = document.querySelector(`.program-card[data-type="internship"][data-id="${internshipId}"]`);
          if (targetCard) selectCard(targetCard);
        }
      } else {
        selectProgramTab('course');
        const courseId = params.get('course') || params.get('programId');
        if (courseId) {
          const targetCard = document.querySelector(`.program-card[data-type="course"][data-id="${courseId}"]`);
          if (targetCard) selectCard(targetCard);
        } else {
          // Select first course as default
          const defaultCard = document.querySelector('.program-card[data-type="course"]');
          if (defaultCard) selectCard(defaultCard);
        }
      }

      // -------------------------------
      // Form submission handling
      // -------------------------------
      const funnelForm = document.getElementById('registration-funnel-form');
      if (funnelForm) {
        funnelForm.addEventListener('submit', async (e) => {
          e.preventDefault();

          const origBtnText = submitBtn.innerHTML;
          submitBtn.disabled = true;
          submitBtn.innerHTML = '<span class="material-symbols-outlined text-sm animate-spin">sync</span> Submitting...';

          const name = nameInput.value.trim();
          const mobile = mobileInput.value.trim();
          const whatsapp = syncWhatsappCheck.checked ? mobile : whatsappInput.value.trim();
          const email = emailInput.value.trim();
          const programType = selectedProgramType;
          const programId = selectedProgramId;
          const programName = selectedProgramName;
          const learningMode = learningModeInput.value;
          const message = messageInput.value.trim();

          try {
            const res = await fetch('/api/register', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                name,
                mobile,
                whatsapp,
                email,
                programType,
                programId,
                programName,
                learningMode,
                message
              })
            });

            const data = await res.json();
            if (res.ok && data.success) {
              // Redirect to success page
              const redirectUrl = `/register/success?name=${encodeURIComponent(name)}&programName=${encodeURIComponent(programName)}&mode=${encodeURIComponent(learningMode)}`;
              window.location.href = redirectUrl;
            } else {
              alert(data.error || 'Failed to submit registration. Please verify details.');
              submitBtn.disabled = false;
              submitBtn.innerHTML = origBtnText;
            }
          } catch (err) {
            console.error(err);
            alert('A connection error occurred. Please try again.');
            submitBtn.disabled = false;
            submitBtn.innerHTML = origBtnText;
          }
        });
      }

    });
  </script>

  <style is:inline>
    .step-active-fade {
      animation: stepFadeIn 0.35s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }
    @keyframes stepFadeIn {
      from {
        opacity: 0;
        transform: translateY(8px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }
  </style>

</Layout>
