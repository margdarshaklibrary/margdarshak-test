---
import Layout from '../../layouts/Layout.astro';
import { getCourses } from '../../data/db.js';

export const prerender = false;

const { id } = Astro.params;
const allCourses = await getCourses();
const course = allCourses.find(c => c.id === id);

const isNotFound = !course || course.status === 'Inactive';

// Fetch related courses

const relatedCourses = allCourses
  .filter(c => c.id !== course?.id && c.status !== 'Inactive')
  .slice(0, 3);

const whatsappLink = !isNotFound
  ? `https://wa.me/919229025257?text=Hi,%20I%20have%20questions%20regarding%20the%20${encodeURIComponent(course.name)}%20course.`
  : '';

// Play store link
const playStoreLink = "https://play.google.com/store/apps/details?id=co.varys.shacc";
const institutePhone = "+919229025257";
const dialPhone = "tel:+919229025257";

// Helper to generate dynamic curriculum timeline based on duration
function getCourseTimeline(duration) {
  const steps = [];
  steps.push({
    title: "Phase 1: Foundations & Core Concepts",
    desc: "Understand the fundamental building blocks, set up necessary toolkits, and master core theoretical models."
  });
  steps.push({
    title: "Phase 2: Hands-on Practical Projects",
    desc: "Implement concepts on industry-standard case studies and build intermediate-level simulations."
  });
  steps.push({
    title: "Phase 3: Advanced Applications",
    desc: "Master expert workflows, optimization techniques, and advanced system/platform modules."
  });
  steps.push({
    title: "Final Phase: 1-Month Practical Internship",
    desc: "Apply your skills on live company projects, receive professional feedback, and build a verified portfolio."
  });
  steps.push({
    title: "Graduation & Placement Support",
    desc: "Get your experience certification stamped, start resume optimization, and secure direct interview references."
  });
  return steps;
}

const timelineSteps = getCourseTimeline(course?.duration);
---

{isNotFound ? (
  <Layout title="Course Not Found - Margdarshak Shikshan Sansthan">
    <section class="py-24 text-center bg-slate-50 relative overflow-hidden flex items-center justify-center min-h-[70vh]">
      <div class="absolute inset-0 bg-gradient-to-t from-slate-100 via-transparent to-transparent opacity-60"></div>
      <div class="max-w-md mx-auto space-y-6 px-6 relative z-10 glass-card-premium p-10 rounded-3xl border border-slate-200 shadow-xl">
        <span class="material-symbols-outlined text-6xl text-secondary animate-pulse font-bold">error</span>
        <h1 class="text-3xl font-headline font-black text-primary">Course Not Found</h1>
        <p class="text-slate-600 text-sm">The course you are looking for does not exist or has been deactivated by our administrator.</p>
        <a href="/courses" class="inline-block w-full py-3 btn-brand-gradient text-white rounded-xl font-bold text-sm hover:scale-[1.02] transition-all shadow-md">
          Go back to Courses
        </a>
      </div>
    </section>
  </Layout>
) : (
  <Layout 
    title={`${course?.name} — Job-Ready Course | Margdarshak Shikshan Sansthan, Darbhanga`} 
    description={course?.shortDescription}
    ogImage={course?.image}
    ogType="website"
    jsonLd={{
      "@context": "https://schema.org",
      "@type": "Course",
      "name": course?.name,
      "description": course?.shortDescription,
      "provider": {
        "@type": "Organization",
        "name": "Margdarshak Shikshan Sansthan",
        "sameAs": "https://margdarshak.in"
      },
      "offers": {
        "@type": "Offer",
        "price": "1000",
        "priceCurrency": "INR",
        "availability": "https://schema.org/InStock",
        "category": "Job-Oriented Course"
      },
      "hasCourseInstance": {
        "@type": "CourseInstance",
        "courseMode": "blended",
        "courseWorkload": course?.duration
      }
    }}
  >
    
    <!-- 1. Hero Section -->
    <section class="hero-gradient text-white py-10 md:py-20 relative overflow-hidden">
      <!-- Glow Blobs -->
      <div class="absolute top-1/4 left-1/10 w-96 h-96 bg-secondary/15 rounded-full filter blur-[120px] pointer-events-none animate-pulse-glow" aria-hidden="true"></div>
      <div class="absolute bottom-10 right-10 w-80 h-80 bg-accent/15 rounded-full filter blur-[100px] pointer-events-none animate-float-slow" aria-hidden="true"></div>

      <div class="max-w-[1440px] mx-auto px-4 md:px-6 relative z-10">
        
        <!-- Breadcrumbs -->
        <div class="flex flex-wrap items-center gap-2 text-xs md:text-sm text-slate-300 font-bold uppercase tracking-wider mb-6">
          <a href="/" class="hover:text-white transition-colors">Home</a>
          <span class="text-slate-500">/</span>
          <a href="/courses" class="hover:text-white transition-colors">Courses</a>
          <span class="text-slate-500">/</span>
          <span class="text-accent">{course?.name}</span>
        </div>

        <!-- Split Grid Layout -->
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
          
          <!-- Hero Details (Left Column) -->
          <div class="lg:col-span-7 space-y-6 text-left">
            <div class="inline-flex items-center gap-2 bg-white/5 border border-white/10 px-4 py-1.5 rounded-full backdrop-blur-md">
              <span class="w-2.5 h-2.5 rounded-full bg-secondary animate-ping"></span>
              <span class="text-xs font-bold uppercase tracking-wider text-accent font-headline">Professional Job-Ready Program</span>
            </div>
            
            <h1 class="text-3xl md:text-5xl lg:text-6xl font-headline font-black leading-tight">
              {course?.name}
            </h1>
            
            <p class="text-slate-300 text-sm md:text-base leading-relaxed font-body max-w-2xl">
              {course?.shortDescription}
            </p>

            <!-- Hero CTA Trigger -->
            <div class="flex flex-wrap gap-4 pt-4">
              <a href={`/register?program=course&course=${course?.id}`} class="px-8 py-4 btn-brand-gradient text-white font-bold rounded-2xl text-sm transition-all shadow-lg hover:scale-105 flex items-center gap-2">
                Register Now <span class="material-symbols-outlined text-sm">arrow_forward</span>
              </a>
              <a href="#overview-section" class="px-8 py-4 bg-white/10 hover:bg-white/15 border border-white/10 text-white font-bold rounded-2xl text-sm transition-all shadow-md flex items-center justify-center">
                Explore Curriculum
              </a>
            </div>
          </div>

          <!-- Hero Image visual card (Right Column) -->
          <div class="lg:col-span-5 relative">
            <div class="absolute -inset-1.5 rounded-3xl bg-gradient-to-r from-secondary to-accent opacity-25 blur-lg animate-float-medium"></div>
            <div class="relative rounded-3xl overflow-hidden border border-white/10 shadow-2xl bg-primary/45 backdrop-blur-xl">
              <img src={course?.image} alt={`${course?.name} course at Margdarshak`} class="w-full h-64 md:h-80 object-cover" loading="eager" fetchpriority="high" decoding="async" width="600" height="320" />
              <div class="absolute inset-0 bg-gradient-to-t from-primary via-transparent to-transparent opacity-85"></div>
              
              <!-- Absolute Details Overlapping Image -->
              <div class="absolute bottom-6 left-6 right-6 flex justify-between items-end">
                <div class="space-y-1">
                  <span class="text-[10px] text-accent uppercase font-black tracking-wider block">Authorized Course Partner</span>
                  <h4 class="text-white font-headline font-bold text-sm">Margdarshak Shikshan Sansthan</h4>
                </div>
                <div class="bg-secondary text-white text-[10px] font-black px-3 py-1.5 rounded-lg border border-secondary/20 shadow-md">
                  ISO 9001:2015
                </div>
              </div>
            </div>
          </div>

        </div>

      </div>
    </section>

    <!-- 2. Quick Course Snapshots -->
    <section class="bg-slate-100 py-8 border-b border-slate-200/60">
      <div class="max-w-[1440px] mx-auto px-4 md:px-6">
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4">
          
          <div class="bg-white p-4 rounded-2xl border border-slate-200/80 shadow-sm flex items-center gap-3">
            <div class="w-10 h-10 rounded-xl bg-secondary/10 flex items-center justify-center text-secondary shrink-0">
              <span class="material-symbols-outlined text-xl">schedule</span>
            </div>
            <div>
              <span class="text-[10px] text-slate-400 font-bold uppercase block">Duration</span>
              <span class="text-xs font-extrabold text-primary">{course?.duration}</span>
            </div>
          </div>

          <div class="bg-white p-4 rounded-2xl border border-slate-200/80 shadow-sm flex items-center gap-3">
            <div class="w-10 h-10 rounded-xl bg-accent/10 flex items-center justify-center text-accent shrink-0">
              <span class="material-symbols-outlined text-xl font-bold">layers</span>
            </div>
            <div>
              <span class="text-[10px] text-slate-400 font-bold uppercase block">Learning Mode</span>
              <span class="text-xs font-extrabold text-primary">Hybrid Classes</span>
            </div>
          </div>

          <div class="bg-white p-4 rounded-2xl border border-slate-200/80 shadow-sm flex items-center gap-3">
            <div class="w-10 h-10 rounded-xl bg-emerald-100 flex items-center justify-center text-emerald-600 shrink-0">
              <span class="material-symbols-outlined text-xl">workspace_premium</span>
            </div>
            <div>
              <span class="text-[10px] text-slate-400 font-bold uppercase block">Certificate</span>
              <span class="text-xs font-extrabold text-primary">ISO Accredited</span>
            </div>
          </div>

          <div class="bg-white p-4 rounded-2xl border border-slate-200/80 shadow-sm flex items-center gap-3">
            <div class="w-10 h-10 rounded-xl bg-blue-50 flex items-center justify-center text-blue-600 shrink-0">
              <span class="material-symbols-outlined text-xl">work</span>
            </div>
            <div>
              <span class="text-[10px] text-slate-400 font-bold uppercase block">Internship</span>
              <span class="text-xs font-extrabold text-primary">1-Month incl.</span>
            </div>
          </div>

          <div class="bg-white p-4 rounded-2xl border border-slate-200/80 shadow-sm flex items-center gap-3">
            <div class="w-10 h-10 rounded-xl bg-purple-50 flex items-center justify-center text-purple-600 shrink-0">
              <span class="material-symbols-outlined text-xl">terminal</span>
            </div>
            <div>
              <span class="text-[10px] text-slate-400 font-bold uppercase block">Projects</span>
              <span class="text-xs font-extrabold text-primary">Live Clients</span>
            </div>
          </div>

          <div class="bg-white p-4 rounded-2xl border border-slate-200/80 shadow-sm flex items-center gap-3">
            <div class="w-10 h-10 rounded-xl bg-amber-50 flex items-center justify-center text-amber-600 shrink-0">
              <span class="material-symbols-outlined text-xl">savings</span>
            </div>
            <div>
              <span class="text-[10px] text-slate-400 font-bold uppercase block">Fee Refund</span>
              <span class="text-xs font-extrabold text-primary">100% Option</span>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- Main Content Layout Section -->
    <section class="py-16 bg-white" id="overview-section">
      <div class="max-w-[1440px] mx-auto px-4 md:px-6">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">
          
          <!-- Left Column Content (Col-span 8) -->
          <div class="lg:col-span-8 space-y-16">
            
            <!-- 3. Course Overview -->
            <div class="space-y-4">
              <h2 class="text-2xl md:text-3xl font-headline font-black text-primary flex items-center gap-2">
                <span class="w-2.5 h-6 bg-secondary rounded-full"></span>
                Course Overview
              </h2>
              <div class="glass-card-premium p-6 md:p-8 rounded-3xl border border-slate-200/60 bg-slate-50/50 shadow-sm">
                <p class="text-slate-600 leading-relaxed text-base md:text-lg font-body">
                  {course?.fullDescription}
                </p>
                <div class="mt-6 pt-6 border-t border-slate-200/60 text-sm text-slate-500 font-semibold flex flex-col sm:flex-row gap-2 sm:gap-6">
                  <div class="flex items-center gap-2">
                    <span class="material-symbols-outlined text-secondary text-lg">school</span>
                    <span><strong>Eligibility:</strong> {course?.eligible}</span>
                  </div>
                </div>
              </div>
            </div>

            <!-- 4. What You'll Learn -->
            <div class="space-y-6">
              <h2 class="text-2xl md:text-3xl font-headline font-black text-primary flex items-center gap-2">
                <span class="w-2.5 h-6 bg-secondary rounded-full"></span>
                What You'll Learn
              </h2>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                {(course?.learnItems || []).map(item => (
                  <div class="flex items-start gap-3 bg-slate-50 p-4 rounded-2xl border border-slate-100 hover:border-secondary/25 transition-all">
                    <span class="material-symbols-outlined text-emerald-500 mt-0.5 font-bold shrink-0">check_circle</span>
                    <span class="text-slate-700 text-sm md:text-base font-medium">{item}</span>
                  </div>
                ))}
              </div>
            </div>

            <!-- 5. Tools & Technologies -->
            <div class="space-y-6">
              <h2 class="text-2xl md:text-3xl font-headline font-black text-primary flex items-center gap-2">
                <span class="w-2.5 h-6 bg-secondary rounded-full"></span>
                Tools & Technologies Covered
              </h2>
              <div class="flex flex-wrap gap-3">
                {(course?.tags || []).map(tag => (
                  <span class="px-5 py-2.5 bg-slate-50 border border-slate-200 text-slate-700 rounded-full font-bold text-xs md:text-sm shadow-sm transition-all hover:bg-secondary hover:text-white hover:border-secondary cursor-default">
                    {tag}
                  </span>
                ))}
                {/* Standard addition if tags are less */}
                {(!course?.tags || course.tags.length < 3) && (
                  <>
                    <span class="px-5 py-2.5 bg-slate-50 border border-slate-200 text-slate-700 rounded-full font-bold text-xs md:text-sm shadow-sm">Industry Best Practices</span>
                    <span class="px-5 py-2.5 bg-slate-50 border border-slate-200 text-slate-700 rounded-full font-bold text-xs md:text-sm shadow-sm">Real Ledgers</span>
                    <span class="px-5 py-2.5 bg-slate-50 border border-slate-200 text-slate-700 rounded-full font-bold text-xs md:text-sm shadow-sm">Live Portals</span>
                  </>
                )}
              </div>
            </div>

            <!-- 6. Learning Journey / Curriculum Timeline -->
            <div class="space-y-8">
              <div>
                <h2 class="text-2xl md:text-3xl font-headline font-black text-primary flex items-center gap-2">
                  <span class="w-2.5 h-6 bg-secondary rounded-full"></span>
                  Learning Journey & Curriculum
                </h2>
                <p class="text-xs md:text-sm text-slate-500 font-medium mt-1">Our comprehensive training layout mapped by development milestones:</p>
              </div>

              <!-- Vertical Timeline -->
              <div class="relative border-l-2 border-slate-200 pl-8 ml-4 space-y-10">
                {timelineSteps.map((step, idx) => (
                  <div class="relative group">
                    <!-- Dot marker -->
                    <div class="absolute -left-[41px] top-0.5 w-6 h-6 rounded-full bg-white border-2 border-slate-300 group-hover:border-secondary transition-colors duration-300 flex items-center justify-center">
                      <div class="w-2.5 h-2.5 rounded-full bg-slate-300 group-hover:bg-secondary transition-colors duration-300"></div>
                    </div>
                    
                    <div class="space-y-1.5">
                      <span class="text-xs font-bold text-secondary font-headline uppercase block">Phase 0{idx + 1}</span>
                      <h4 class="text-slate-800 font-headline font-black text-base md:text-lg leading-snug group-hover:text-primary transition-colors">{step.title}</h4>
                      <p class="text-slate-500 text-xs md:text-sm leading-relaxed font-body max-w-2xl">{step.desc}</p>
                    </div>
                  </div>
                ))}
              </div>
            </div>

            <!-- 7. Internship Experience -->
            <div class="space-y-6">
              <h2 class="text-2xl md:text-3xl font-headline font-black text-primary flex items-center gap-2">
                <span class="w-2.5 h-6 bg-secondary rounded-full"></span>
                Integrated Internship Experience
              </h2>
              <div class="glass-card-premium p-6 md:p-8 rounded-3xl border border-secondary/15 bg-secondary/[0.01] space-y-6">
                <div class="flex items-center gap-4">
                  <div class="w-12 h-12 rounded-2xl bg-secondary/10 flex items-center justify-center text-secondary border border-secondary/20">
                    <span class="material-symbols-outlined text-2xl font-bold">work</span>
                  </div>
                  <div>
                    <h3 class="text-lg md:text-xl font-headline font-black text-primary">1-Month Smart Internship Included</h3>
                    <p class="text-xs text-slate-500 font-medium">Bridges training duration into practical corporate workflows</p>
                  </div>
                </div>

                <p class="text-slate-700 text-sm md:text-base leading-relaxed">
                  {course?.internshipIncluded}. You will work side-by-side with senior mentors to practice real billing, accounts reconciliation, web coding, or digital marketing campaigns. Highlights include:
                </p>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                  <div class="flex items-start gap-2 bg-white p-4 rounded-xl border border-slate-100 shadow-sm">
                    <span class="material-symbols-outlined text-secondary text-lg mt-0.5">terminal</span>
                    <div class="text-xs">
                      <strong class="text-slate-800 font-bold block mb-0.5">Live Simulation</strong>
                      <span class="text-slate-500 leading-normal">Work on actual business invoice logs, web files, or traffic calendars.</span>
                    </div>
                  </div>
                  <div class="flex items-start gap-2 bg-white p-4 rounded-xl border border-slate-100 shadow-sm">
                    <span class="material-symbols-outlined text-secondary text-lg mt-0.5">group</span>
                    <div class="text-xs">
                      <strong class="text-slate-800 font-bold block mb-0.5">Mentorship</strong>
                      <span class="text-slate-500 leading-normal">Get weekly reviews, code analysis, or ledger audits from senior specialists.</span>
                    </div>
                  </div>
                  <div class="flex items-start gap-2 bg-white p-4 rounded-xl border border-slate-100 shadow-sm">
                    <span class="material-symbols-outlined text-secondary text-lg mt-0.5">badge</span>
                    <div class="text-xs">
                      <strong class="text-slate-800 font-bold block mb-0.5">Official Experience Letter</strong>
                      <span class="text-slate-500 leading-normal">Complete tasks to earn a verified Corporate Internship Certificate.</span>
                    </div>
                  </div>
                  <div class="flex items-start gap-2 bg-white p-4 rounded-xl border border-slate-100 shadow-sm">
                    <span class="material-symbols-outlined text-secondary text-lg mt-0.5">photo_library</span>
                    <div class="text-xs">
                      <strong class="text-slate-800 font-bold block mb-0.5">Portfolio Building</strong>
                      <span class="text-slate-500 leading-normal">Assemble all internship assignments into a ready portfolio to present to employers.</span>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <!-- 8. Certification Details -->
            <div class="space-y-6">
              <h2 class="text-2xl md:text-3xl font-headline font-black text-primary flex items-center gap-2">
                <span class="w-2.5 h-6 bg-secondary rounded-full"></span>
                Official Experience & Course Certification
              </h2>

              <div class="grid grid-cols-1 md:grid-cols-12 gap-8 items-center bg-slate-50 p-6 md:p-8 rounded-3xl border border-slate-200 shadow-sm">
                <!-- Trust Text (Left Side) -->
                <div class="md:col-span-7 space-y-4">
                  <div class="inline-block bg-accent/20 text-primary border border-accent/30 text-[10px] font-extrabold px-3 py-1 rounded-full uppercase tracking-wider">
                    ISO 9001:2015 Verified NGO
                  </div>
                  <h4 class="text-xl font-headline font-bold text-primary">
                    Certified Professional Record
                  </h4>
                  <p class="text-slate-600 text-sm leading-relaxed font-body">
                    {course?.certificateDetails} All certificates come with a unique verification ID which can be authenticated on our portal by employers worldwide.
                  </p>
                  <ul class="space-y-2 text-xs text-slate-700 font-semibold font-headline">
                    <li class="flex items-center gap-2">
                      <span class="material-symbols-outlined text-secondary text-base">check_circle</span> Valid for both Public & Private sector roles
                    </li>
                    <li class="flex items-center gap-2">
                      <span class="material-symbols-outlined text-secondary text-base">check_circle</span> Unique registration database verification ID
                    </li>
                    <li class="flex items-center gap-2">
                      <span class="material-symbols-outlined text-secondary text-base">check_circle</span> Stamped authorization from Registered NGO
                    </li>
                  </ul>
                </div>

                <!-- Styled HTML Mock Certificate Frame (Right Side) -->
                <div class="md:col-span-5 relative">
                  <div class="absolute -inset-1 rounded-2xl bg-gradient-to-r from-accent to-secondary opacity-15 blur-md"></div>
                  <div class="relative bg-white border-4 border-slate-200 p-4 rounded-2xl shadow-lg space-y-4 text-center select-none overflow-hidden min-h-[220px] flex flex-col justify-between">
                    <div class="absolute -right-6 -bottom-6 w-24 h-24 bg-accent/10 rounded-full"></div>
                    
                    <div class="space-y-1">
                      <div class="text-[9px] uppercase tracking-widest text-slate-400 font-bold">Certificate of Completion</div>
                      <div class="w-6 h-0.5 bg-accent mx-auto"></div>
                    </div>
                    
                    <div class="space-y-1 py-2">
                      <div class="text-[7px] text-slate-400 uppercase">This is presented to</div>
                      <div class="text-xs font-headline font-bold text-primary border-b border-dashed border-slate-300 w-3/4 mx-auto pb-0.5">Your Full Name</div>
                      <div class="text-[6px] text-slate-500 max-w-[90%] mx-auto mt-1 leading-normal font-medium font-body">For successful course completion and practical assignments in {course?.name}.</div>
                    </div>

                    <div class="flex justify-between items-center pt-2 border-t border-slate-100 text-[6px] text-slate-400">
                      <div>
                        <div class="font-bold text-slate-700">Margdarshak</div>
                        <div>Authorized Signature</div>
                      </div>
                      <div class="w-8 h-8 rounded-full bg-accent/15 border border-accent/20 flex items-center justify-center font-black text-accent text-[8px]">
                        SEAL
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <!-- 9. Career Opportunities -->
            <div class="space-y-6">
              <h2 class="text-2xl md:text-3xl font-headline font-black text-primary flex items-center gap-2">
                <span class="w-2.5 h-6 bg-secondary rounded-full"></span>
                Career Opportunities
              </h2>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                {(course?.careerOpportunities || []).map(job => (
                  <div class="flex items-center gap-3 bg-slate-50 p-4 rounded-xl border border-slate-100 hover:border-secondary/20 transition-all shadow-sm">
                    <span class="material-symbols-outlined text-secondary font-bold">trending_flat</span>
                    <span class="text-slate-700 font-semibold text-sm md:text-base">{job}</span>
                  </div>
                ))}
              </div>
            </div>

            <!-- 10. Refund Opportunity -->
            <div class="space-y-6">
              <div class="relative rounded-3xl overflow-hidden shadow-2xl bg-gradient-to-br from-primary to-slate-900 border border-white/10 text-white p-8 md:p-10">
                <div class="absolute -right-20 -bottom-20 w-64 h-64 bg-secondary/10 rounded-full filter blur-3xl pointer-events-none"></div>
                <div class="absolute -left-20 -top-20 w-60 h-60 bg-accent/5 rounded-full filter blur-3xl pointer-events-none"></div>
                
                <div class="grid grid-cols-1 md:grid-cols-12 gap-8 items-center relative z-10">
                  <div class="md:col-span-8 space-y-5">
                    <div class="inline-flex items-center gap-2 bg-secondary/25 border border-secondary/35 px-4 py-1 rounded-full">
