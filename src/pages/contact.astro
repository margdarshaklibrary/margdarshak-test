---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact Us - Margdarshak Shikshan Sansthan" description="Get in touch with Margdarshak Shikshan Sansthan in Darbhanga. Access our address, mobile/WhatsApp numbers, opening hours, and contact form.">
  
  <!-- Page Header -->
  <section class="hero-gradient text-white py-16">
    <div class="max-w-7xl mx-auto px-6 md:px-8 text-center space-y-4">
      <div class="inline-block bg-white/10 px-4 py-1.5 rounded-full text-xs font-bold uppercase tracking-wider">
        Get In Touch
      </div>
      <h1 class="text-3xl md:text-5xl font-headline font-black">
        Contact Our Office
      </h1>
      <p class="text-slate-300 max-w-2xl mx-auto text-base md:text-lg">
        Have questions? Our advisors are here to help you choose the right program.
      </p>
    </div>
  </section>

  <!-- Main Contact Section -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-6 md:px-8 grid grid-cols-1 lg:grid-cols-12 gap-12">
      
      <!-- Contact details & map (Left Column) -->
      <div class="lg:col-span-6 space-y-8">
        <div>
          <h2 class="text-2xl font-headline font-bold text-primary mb-3">Our Office Information</h2>
          <p class="text-slate-500 text-sm">Feel free to call us or visit our modern computer center during work hours.</p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
          <!-- Address -->
          <div class="bg-background p-6 rounded-2xl border border-slate-100 shadow-sm">
            <span class="material-symbols-outlined text-3xl text-secondary mb-3">location_on</span>
            <h4 class="font-bold text-slate-800 text-base mb-1">Center Address</h4>
            <p class="text-slate-500 text-sm leading-relaxed">
              Near New Variety Readymade, VIP Road, Benta Chowk, Laheriasarai, Darbhanga – 846003 (Bihar)
            </p>
          </div>

          <!-- Phone / WhatsApp -->
          <div class="bg-background p-6 rounded-2xl border border-slate-100 shadow-sm">
            <span class="material-symbols-outlined text-3xl text-success mb-3">chat</span>
            <h4 class="font-bold text-slate-800 text-base mb-1">WhatsApp & Call</h4>
            <p class="text-slate-500 text-sm mb-2">Direct career support helpline:</p>
            <a href="tel:+919229025257" class="text-primary font-bold text-sm block hover:underline">+91 92290 25257</a>
            <a href="https://wa.me/919229025257" target="_blank" class="text-success font-bold text-sm block hover:underline">Chat on WhatsApp</a>
          </div>

          <!-- Opening Hours -->
          <div class="bg-background p-6 rounded-2xl border border-slate-100 shadow-sm">
            <span class="material-symbols-outlined text-3xl text-primary mb-3">schedule</span>
            <h4 class="font-bold text-slate-800 text-base mb-1">Office Hours</h4>
            <ul class="text-slate-500 text-xs space-y-1">
              <li><strong>Monday - Saturday:</strong> 9:00 AM - 6:00 PM</li>
              <li><strong>Sunday:</strong> Closed</li>
            </ul>
          </div>

          <!-- Support Mail -->
          <div class="bg-background p-6 rounded-2xl border border-slate-100 shadow-sm">
            <span class="material-symbols-outlined text-3xl text-accent mb-3">mail</span>
            <h4 class="font-bold text-slate-800 text-base mb-1">Email Support</h4>
            <p class="text-slate-500 text-sm mb-1">General inquiries:</p>
            <a href="mailto:info@margdarshakedu.com" class="text-primary font-bold text-sm block hover:underline">info@margdarshakedu.com</a>
          </div>
        </div>

        <!-- Google Map Placeholder -->
        <div class="rounded-3xl overflow-hidden h-72 border border-slate-200 shadow-md relative group">
          <div class="absolute inset-0 bg-slate-900/10 pointer-events-none group-hover:bg-transparent transition-all"></div>
          <img alt="Map highlighting Darbhanga location" class="w-full h-full object-cover filter grayscale hover:grayscale-0 transition-all duration-300" src="/assets/f3e61e48da7279b4e812d3aaa080c78b.png" />
          <div class="absolute bottom-4 left-4 bg-white px-4 py-2 rounded-lg shadow-lg text-xs font-bold text-primary border border-slate-100">
            Benta Chowk, Darbhanga
          </div>
        </div>

        <!-- Social Media Links -->
        <div class="space-y-3">
          <h4 class="font-bold text-primary">Follow Our Updates</h4>
          <div class="flex gap-4">
            <a href="#" class="w-10 h-10 bg-slate-100 rounded-lg flex items-center justify-center text-primary hover:bg-primary hover:text-white transition-all">
              <span class="material-symbols-outlined text-lg">public</span>
            </a>
            <a href="https://wa.me/919229025257" target="_blank" class="w-10 h-10 bg-slate-100 rounded-lg flex items-center justify-center text-success hover:bg-success hover:text-white transition-all">
              <span class="material-symbols-outlined text-lg">chat</span>
            </a>
            <a href="#" class="w-10 h-10 bg-slate-100 rounded-lg flex items-center justify-center text-[#d9383a] hover:bg-[#d9383a] hover:text-white transition-all">
              <span class="material-symbols-outlined text-lg">play_circle</span>
            </a>
          </div>
        </div>
      </div>

      <!-- Contact form (Right Column) -->
      <div class="lg:col-span-6 bg-slate-50 p-8 md:p-10 rounded-3xl border border-slate-200/60 shadow-xl space-y-6">
        <div>
          <h3 class="text-2xl font-headline font-bold text-primary">Send Us A Message</h3>
          <p class="text-slate-500 text-sm mt-1">Fill out the quick contact inquiry, and we will get back to you shortly.</p>
        </div>

        <!-- Contact Form -->
        <form class="space-y-6">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <div class="space-y-2">
              <label class="text-sm font-bold text-slate-700 block" for="contact-name">Full Name</label>
              <input id="contact-name" class="w-full px-4 py-3 rounded-xl border border-slate-300 bg-white focus:border-primary focus:ring-1 focus:ring-primary focus:outline-none text-sm" placeholder="Enter your full name" type="text" required />
            </div>
            <div class="space-y-2">
              <label class="text-sm font-bold text-slate-700 block" for="contact-phone">Phone Number</label>
              <input id="contact-phone" class="w-full px-4 py-3 rounded-xl border border-slate-300 bg-white focus:border-primary focus:ring-1 focus:ring-primary focus:outline-none text-sm" placeholder="Enter your mobile" type="tel" required />
            </div>
          </div>
          <div class="space-y-2">
            <label class="text-sm font-bold text-slate-700 block" for="contact-email">Email Address</label>
            <input id="contact-email" class="w-full px-4 py-3 rounded-xl border border-slate-300 bg-white focus:border-primary focus:ring-1 focus:ring-primary focus:outline-none text-sm" placeholder="Enter email" type="email" required />
          </div>
          <div class="space-y-2">
            <label class="text-sm font-bold text-slate-700 block" for="contact-program">Interested Program</label>
            <select id="contact-program" class="w-full px-4 py-3 rounded-xl border border-slate-300 bg-white focus:border-primary focus:ring-1 focus:ring-primary focus:outline-none text-sm">
              <option>DCA / ADCA Course</option>
              <option>Web Development Course</option>
              <option>Digital Marketing Course</option>
              <option>GST & Return Filing Course</option>
              <option>Income Tax Return Filing Course</option>
              <option>Tally & Advanced Excel Course</option>
              <option>1-Month Practical Internship</option>
              <option>General Career Counseling Inquiry</option>
            </select>
          </div>
          <div class="space-y-2">
            <label class="text-sm font-bold text-slate-700 block" for="contact-msg">Message</label>
            <textarea id="contact-msg" class="w-full px-4 py-3 rounded-xl border border-slate-300 bg-white focus:border-primary focus:ring-1 focus:ring-primary focus:outline-none text-sm h-32" placeholder="Tell us how we can help you..." required></textarea>
          </div>
          
          <button class="w-full py-4 bg-primary text-white font-bold rounded-xl hover:bg-slate-800 transition-all shadow-lg hover:shadow-primary/20 flex items-center justify-center gap-2" type="submit">
            <span class="material-symbols-outlined text-sm font-bold">send</span> Submit Message
          </button>
        </form>

        <div id="form-feedback" class="hidden bg-success/10 text-success p-4 rounded-xl border border-success/30 text-center font-semibold text-sm">
          Thank you for contacting us! We will reach out to you shortly.
        </div>
      </div>

    </div>
  </section>

  <script is:inline>
    // Simple contact form submission handling
    const form = document.querySelector('form');
    const feedback = document.getElementById('form-feedback');

    if (form && feedback) {
      form.addEventListener('submit', (e) => {
        e.preventDefault();
        form.classList.add('hidden');
        feedback.classList.remove('hidden');
      });
    }
  </script>

</Layout>
